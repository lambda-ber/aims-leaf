            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path lambdaber:related_entity ] ;
    sh:targetClass lambdaber:FTIRImage .

lambdaber:FluorescenceImage a sh:NodeShape ;
    sh:closed true ;
    sh:description "Fluorescence microscopy image capturing specific molecular targets through fluorescent labeling" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class nmdc:QuantityValue ;
            sh:description "Excitation wavelength, typically specified in nanometers. Data providers may specify alternative units by including the unit in the QuantityValue." ;
