            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path <https://w3id.org/aims-leaf/plant/ancestral_data> ],
        [ sh:datatype xsd:string ;
            sh:description "Use this field to provide information about treatments that are not captured accurately by any of the other available treatment categories" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 56 ;
            sh:path <https://w3id.org/aims-leaf/plant/other_treatment_regimen> ],
        [ sh:datatype xsd:string ;
            sh:description "The age of the plant from which the tissue was sampled" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 32 ;
            sh:path <https://w3id.org/aims-leaf/plant/plant_age> ],
        [ sh:datatype xsd:string ;
            sh:description "Reference genome and annotation to be used for analysis" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path <https://w3id.org/aims-leaf/plant/reference_genome> ],
        [ sh:datatype xsd:string ;
            sh:description "Plant ontology term corresponding to plant structure sampled; see https://planteome.org. May include multiple terms separated by semicolons" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path <https://w3id.org/aims-leaf/plant/tissue_plant_ontology_term> ],
        [ sh:datatype xsd:string ;
            sh:description "Description of the time point sampled, applicable to samples that are part of time course experiments" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path <https://w3id.org/aims-leaf/plant/experimental_time_point_description> ],
        [ sh:datatype xsd:string ;
            sh:description "List of chemical compounds administered to the host or site where sampling occurred, and when" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 40 ;
            sh:path <https://w3id.org/aims-leaf/plant/chemical_administration> ],
        [ sh:datatype xsd:string ;
            sh:description "The major environmental system the sample or specimen came from. The system(s) identified should have a coarse spatial grain" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path <https://w3id.org/aims-leaf/plant/broad_scale_environmental_context> ;
            sh:pattern ".*\\[ENVO:\\d+\\]$" ],
        [ sh:datatype xsd:string ;
            sh:description "Information about treatment involving an exposure to a given amount of rainfall" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 54 ;
            sh:path <https://w3id.org/aims-leaf/plant/rainfall_regimen> ],
        [ sh:datatype xsd:string ;
            sh:description "Use of conditions with differing gaseous environments" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 45 ;
            sh:path <https://w3id.org/aims-leaf/plant/gaseous_environment> ],
        [ sh:datatype xsd:string ;
            sh:description "General specification of the media for growing the plants or tissue cultured samples" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path <https://w3id.org/aims-leaf/plant/growth_medium> ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Elevation (in meters) of the sampling site as measured by the vertical distance from mean sea level" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 24 ;
            sh:path <https://w3id.org/aims-leaf/plant/elevation_meters> ],
        [ sh:description "Stage that takes into account effect of genotype & environment effects. Requires in depth knowledge about features of model organism doi: 10.1105/TPC.010011" ;
            sh:in ( "Stage_0" "Stage_0.10" "Stage_0.50" "Stage_0.70" "Stage_1" "Stage_1.02" "Stage_1.03" "Stage_1.04" "Stage_1.05" "Stage_1.06" "Stage_1.07" "Stage_1.08" "Stage_1.09" "Stage_1.10" "Stage_1.11" "Stage_1.12" "Stage_1.13" "Stage_1.14" "Stage_3" "Stage_3.20" "Stage_3.50" "Stage_3.70" "Stage_3.90" "Stage_5" "Stage_5.10" "Stage_6" "Stage_6.00" "Stage_6.10" "Stage_6.30" "Stage_6.50" "Stage_6.90" "Stage_8" "Stage_8.00" "Stage_9" "Stage_9.70" ) ;
            sh:maxCount 1 ;
            sh:order 34 ;
            sh:path <https://w3id.org/aims-leaf/plant/arabadopsis_phenotype_stage> ],
        [ sh:class lambdaber:Sample ;
            sh:description "Reference to parent sample for derivation tracking" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 73 ;
            sh:path lambdaber:parent_sample_id ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Sample purity, typically specified as a percentage (range: 0-100). Data providers may specify as decimal fraction by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 74 ;
            sh:path lambdaber:purity_percentage ],
        [ sh:class lambdaber:OntologyTerm ;
            sh:description "Anatomical part or tissue (e.g., UBERON:0008945 for leaf)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 71 ;
            sh:path lambdaber:anatomy ],
        [ sh:datatype xsd:string ;
            sh:description "Treatment involving use of mutagens" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 41 ;
            sh:path <https://w3id.org/aims-leaf/plant/chemical_mutagen> ],
        [ sh:description "Type of biological sample" ;
            sh:in ( "protein" "nucleic_acid" "complex" "membrane_protein" "virus" "organelle" "tissue_section" "tissue" "organism" "soil" "rock" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 64 ;
            sh:path lambdaber:sample_type ],
        [ sh:datatype xsd:string ;
            sh:description "Information about any mechanical damage exerted on the plant" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 58 ;
            sh:path <https://w3id.org/aims-leaf/plant/mechanical_damage> ],
        [ sh:class lambdaber:StorageConditions ;
            sh:description "Storage conditions for the sample" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 69 ;
            sh:path lambdaber:storage_conditions ],
        [ sh:datatype xsd:string ;
            sh:description "Information about treatment involving an exposure to varying temperatures" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 35 ;
            sh:path <https://w3id.org/aims-leaf/plant/air_temperature_regimen> ],
        [ sh:class lambdaber:OntologyTerm ;
            sh:description "Source organism for the sample (e.g., NCBITaxon:3702 for Arabidopsis thaliana)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 70 ;
            sh:path lambdaber:organism ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Globally unique identifier as an IRI or CURIE for machine processing and external references. Used for linking data across systems and semantic web integration." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 76 ;
            sh:path lambdaber:id ],
        [ sh:datatype xsd:string ;
            sh:description "Isolate or mutant name" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path <https://w3id.org/aims-leaf/plant/isolate> ],
        [ sh:datatype xsd:string ;
            sh:description "The number and relationship between the tissues if multiple tissue samples were combined into a single container" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://w3id.org/aims-leaf/plant/combined_tissue_description> ],
        [ sh:datatype xsd:string ;
            sh:description "Detailed description of fertilizer application" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 42 ;
            sh:path <https://w3id.org/aims-leaf/plant/fertilizer_administration> ],
        [ sh:datatype xsd:string ;
            sh:description "The time of sampling, either as an instance (single point in time) or interval. All valid ISO8601 formats are acceptable" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path <https://w3id.org/aims-leaf/plant/collection_date_time> ],
        [ sh:datatype xsd:string ;
            sh:description "Samples that are biological replicates should have the same group name" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://w3id.org/aims-leaf/plant/biological_replicate_sample_group_name> ],
        [ sh:datatype xsd:string ;
            sh:description "Culture collection name and ID from which the original plant germplasm was sourced" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path <https://w3id.org/aims-leaf/plant/germplasm_collection_id> ],
        [ sh:datatype xsd:string ;
            sh:description "The geographical origin of the sample as defined by the country or sea name followed by specific region name" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path <https://w3id.org/aims-leaf/plant/region_locality> ],
        [ sh:datatype xsd:string ;
            sh:description "The entity or entities which are in the sample or specimen's local vicinity and which you believe have significant causal influences on your sample or specimen" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path <https://w3id.org/aims-leaf/plant/local_environmental_context> ;
            sh:pattern ".*\\[ENVO:\\d+\\]$" ],
        [ sh:datatype xsd:string ;
            sh:description "Human-friendly laboratory identifier or facility code for the sample (e.g., 'ALS-12.3.1-SAMPLE-001', 'LAB-PROT-2024-01'). Used for local reference and tracking within laboratory workflows." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 63 ;
            sh:path lambdaber:sample_code ],
        [ sh:datatype xsd:string ;
            sh:description "Information about treatment involving an exposure to light, including intensity, timing, and quality" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 50 ;
            sh:path <https://w3id.org/aims-leaf/plant/light_regimen> ],
        [ sh:datatype xsd:string ;
            sh:description "Genetic modifications of the genome of an organism, which may occur naturally by spontaneous mutation, or be introduced by some experimental means" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path <https://w3id.org/aims-leaf/plant/genetic_modification> ],
        [ sh:datatype xsd:string ;
            sh:description "Information about treatment involving exposure of plant or a plant part to a particular radiation regimen" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 49 ;
            sh:path <https://w3id.org/aims-leaf/plant/radiation_regimen> ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Sample concentration, typically specified in mg/mL or µM. Data providers may specify alternative units (e.g., molar, g/L) by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 66 ;
            sh:path lambdaber:concentration ],
        [ sh:datatype xsd:string ;
            sh:description "Stage of the disease at the time of sample collection, e.g. inoculation, penetration, infection, growth and reproduction, dissemination of pathogen" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 62 ;
            sh:path <https://w3id.org/aims-leaf/plant/sample_disease_stage> ],
        [ sh:datatype xsd:string ;
            sh:description "Detailed description of the makeup of the plant growth medium" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path <https://w3id.org/aims-leaf/plant/growth_medium_composition> ],
        [ sh:datatype xsd:string ;
            sh:description "Information about treatment involving use of salts as supplement to liquid and soil growth media" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 53 ;
            sh:path <https://w3id.org/aims-leaf/plant/salt_regimen> ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Molecular weight, typically specified in kilodaltons (kDa). Data providers may specify alternative units (e.g., Daltons, g/mol) by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 65 ;
            sh:path lambdaber:molecular_weight ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Temperature (in degrees Celsius) of the sample at time of sampling" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 25 ;
            sh:path <https://w3id.org/aims-leaf/plant/temperature> ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title for this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 77 ;
            sh:path dcterms:title ],
        [ sh:datatype xsd:string ;
            sh:description "A detailed textual description of this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 78 ;
            sh:path lambdaber:description ],
        [ sh:description "Type of facility where the sampled plant was grown" ;
            sh:in ( "growth_chamber" "greenhouse" "irrigated_field" "wild" "laboratory" "field" "other" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 29 ;
            sh:path <https://w3id.org/aims-leaf/plant/growth_facility> ],
        [ sh:datatype xsd:float ;
            sh:description "The geographical origin of the sample as defined by longitude. The value should be reported in decimal degrees, limited to 8 decimal points, and in WGS84 system" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path <https://w3id.org/aims-leaf/plant/longitude> ],
        [ sh:datatype xsd:float ;
            sh:description "The geographical origin of the sample as defined by latitude. The value should be reported in decimal degrees, limited to 8 decimal points, and in WGS84 system" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path <https://w3id.org/aims-leaf/plant/latitude> ],
        [ sh:datatype xsd:string ;
            sh:description "Information about treatment involving use of insecticides" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 43 ;
            sh:path <https://w3id.org/aims-leaf/plant/insecticide_regimen> ],
        [ sh:datatype xsd:integer ;
            sh:description "Unique identifier from the NCBI taxonomy database" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path <https://w3id.org/aims-leaf/plant/ncbi_taxonomy_id> ] ;
    sh:targetClass <https://w3id.org/aims-leaf/plant/PlantSample> .

<https://w3id.org/aims-leaf/plant/PlantSamplePreparation> a sh:NodeShape ;
    sh:closed true ;
    sh:description "A process that prepares a plant sample for analysis" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Detailed protocol description" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path lambdaber:protocol_description ],
        [ sh:datatype xsd:string ;
            sh:description "Ion-exchange column used" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 41 ;
            sh:path lambdaber:iex_column ],
        [ sh:datatype xsd:string ;
            sh:description "Size-exclusion column used" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 43 ;
            sh:path lambdaber:sec_column ],
        [ sh:datatype xsd:string ;
            sh:description "Buffer for size-exclusion chromatography" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 44 ;
            sh:path lambdaber:sec_buffer ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "The time between sampling and sample preservation, minutes" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path <https://w3id.org/aims-leaf/plant/harvest_to_preservation_time> ],
        [ sh:datatype xsd:string ;
            sh:description "Type of affinity chromatography" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path lambdaber:affinity_type ],
        [ sh:datatype xsd:string ;
            sh:description "A brief description of any processing applied to the sample during or after retrieving the sample from environment, or a link to the relevant protocol(s) performed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://w3id.org/aims-leaf/plant/sample_material_processing> ],
        [ sh:datatype xsd:string ;
            sh:description "Assessment of protein aggregation state" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 50 ;
            sh:path lambdaber:aggregation_assessment ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Thickness of support layer" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path <https://w3id.org/aims-leaf/plant/support_thickness> ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title for this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 53 ;
            sh:path dcterms:title ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Growth temperature, typically specified in degrees Celsius. Data providers may specify alternative units (e.g., Kelvin) by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path lambdaber:growth_temperature_c ],
        [ sh:datatype xsd:string ;
            sh:description "Material used to stabilize for sectioning, e.g. OCT, parafin wax " ;
            sh:maxCount 1 ;
