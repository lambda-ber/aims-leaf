@prefix CHMO: <http://purl.obolibrary.org/obo/CHMO_> .
@prefix GO: <http://purl.obolibrary.org/obo/GO_> .
@prefix ROR: <https://ror.org/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix lambdaber: <https://w3id.org/aims-leaf/> .
@prefix linkml: <https://w3id.org/linkml/> .
@prefix mmCIF: <http://mmcif.wwpdb.org/dictionaries/mmcif_pdbx_v50.dic/Items/> .
@prefix nmdc: <https://w3id.org/nmdc/> .
@prefix nsls2: <https://github.com/NSLS2/BER-LAMBDA/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

lambdaber:AttributeGroup a sh:NodeShape ;
    sh:closed false ;
    sh:description "A grouping of related data attributes that form a logical unit" ;
    sh:ignoredProperties ( lambdaber:ethane_temperature lambdaber:beam_size_um nsls2:Loop_Size lambdaber:rg lambdaber:amplitude_contrast <https://w3id.org/aims-leaf/functional_annotation/ligand_id> <https://w3id.org/aims-leaf/functional_annotation/is_drug_like> lambdaber:drop_volume_nl lambdaber:value lambdaber:map_sharpening_bfactor lambdaber:cryoprotectant lambdaber:wavelength_a lambdaber:total_frames lambdaber:gold_standard lambdaber:plasma_treatment lambdaber:crystallization_method <https://w3id.org/aims-leaf/functional_annotation/database_url> lambdaber:drift_total <https://w3id.org/aims-leaf/functional_annotation/state_id> lambdaber:grid_material lambdaber:vitrification_method lambdaber:symmetry lambdaber:defocus_step lambdaber:defocus_search_max lambdaber:gpu_hours lambdaber:power_score lambdaber:components lambdaber:unit_cell_alpha lambdaber:hole_size <https://w3id.org/aims-leaf/functional_annotation/characteristic_features> lambdaber:anom_corr rdf:type lambdaber:ramachandran_outliers_percent lambdaber:wilson_b_factor_a2 lambdaber:average_b_factor_a2 <https://w3id.org/aims-leaf/functional_annotation/free_energy> lambdaber:voltage_used_in_estimation lambdaber:r_pim lambdaber:support_film lambdaber:dose_per_frame lambdaber:mean_i_over_sigma_i lambdaber:cs_used_in_estimation <https://w3id.org/aims-leaf/functional_annotation/database_name> lambdaber:unit_cell_gamma lambdaber:frame_rate lambdaber:seeding_type <https://w3id.org/aims-leaf/functional_annotation/property_type> lambdaber:resolution_0_5 lambdaber:resolution_high_shell_a lambdaber:unit <https://w3id.org/aims-leaf/functional_annotation/binding_affinity_type> lambdaber:protein_concentration_mg_per_ml lambdaber:glow_discharge_applied lambdaber:blotter_height lambdaber:blot_time lambdaber:optimized_condition <https://w3id.org/aims-leaf/functional_annotation/interaction_distance> lambdaber:additives lambdaber:crystal_notes lambdaber:output_binning <https://w3id.org/aims-leaf/functional_annotation/measurement_conditions> lambdaber:sample_applied_volume lambdaber:r_merge lambdaber:flash_cooling_method lambdaber:resolution lambdaber:box_size lambdaber:pixel_size_calibrated lambdaber:completeness_high_res_shell_percent <https://w3id.org/aims-leaf/functional_annotation/error> lambdaber:space_group lambdaber:defocus_search_min <https://w3id.org/aims-leaf/functional_annotation/ligand_name> lambdaber:unit_cell_c lambdaber:attenuator lambdaber:model_name lambdaber:oscillation_per_image_deg <https://w3id.org/aims-leaf/functional_annotation/binding_site_residues> <https://w3id.org/aims-leaf/functional_annotation/interaction_type> lambdaber:multiplicity lambdaber:protein_buffer lambdaber:glow_discharge_current lambdaber:drop_ratio_protein_to_reservoir lambdaber:cryoprotectant_concentration lambdaber:temperature lambdaber:bfactor_dose_weighting <https://w3id.org/aims-leaf/functional_annotation/ligand_smiles> lambdaber:soak_conditions lambdaber:total_dose lambdaber:duration <https://w3id.org/aims-leaf/functional_annotation/pdb_entries> lambdaber:beam_energy lambdaber:unit_cell_beta lambdaber:screen_name lambdaber:picking_method <https://w3id.org/aims-leaf/functional_annotation/rmsd_from_reference> lambdaber:cc_half lambdaber:crystal_size_um lambdaber:chamber_temperature lambdaber:vitrification_instrument lambdaber:ph lambdaber:terms lambdaber:blot_force <https://w3id.org/aims-leaf/functional_annotation/experimental_method> lambdaber:resolution_0_143 lambdaber:beam_center_x_px lambdaber:humidity lambdaber:storage_gb nsls2:Temperature lambdaber:humidity_percentage lambdaber:glow_discharge_time lambdaber:unit_cell_b <https://w3id.org/aims-leaf/functional_annotation/druggability_score> lambdaber:initial_hit_condition lambdaber:dose_weighting lambdaber:exposure_time <https://w3id.org/aims-leaf/functional_annotation/population> lambdaber:anomalous_used lambdaber:signal_to_noise lambdaber:flux_photons_per_s lambdaber:clashscore lambdaber:molprobity_score lambdaber:unit_cell_a <https://w3id.org/aims-leaf/functional_annotation/is_cofactor> lambdaber:threshold lambdaber:split_strategy lambdaber:r_free lambdaber:anom_sig_ano lambdaber:cpu_hours lambdaber:patch_size lambdaber:seed_stock_dilution <https://w3id.org/aims-leaf/functional_annotation/state_name> lambdaber:transmission_percent lambdaber:memory_gb lambdaber:pixel_size <https://w3id.org/aims-leaf/functional_annotation/binding_affinity_unit> lambdaber:wait_time <https://w3id.org/aims-leaf/functional_annotation/database_id> lambdaber:atmosphere lambdaber:r_work lambdaber:anisotropic_correction lambdaber:reservoir_volume_ul lambdaber:detector_distance_mm lambdaber:ramachandran_favored_percent lambdaber:detector_mode lambdaber:temperature_k lambdaber:temperature_c lambdaber:pressure lambdaber:model_source lambdaber:completeness lambdaber:r_factor lambdaber:soak_compound lambdaber:binning lambdaber:frame_grouping lambdaber:model_file_path lambdaber:beam_center_y_px lambdaber:collection_mode lambdaber:strategy_notes lambdaber:ncc_score lambdaber:blotter_setting <https://w3id.org/aims-leaf/functional_annotation/binding_affinity> lambdaber:blot_number <https://w3id.org/aims-leaf/functional_annotation/last_updated> lambdaber:glow_discharge_pressure lambdaber:grid_type lambdaber:glow_discharge_atmosphere lambdaber:optimization_strategy lambdaber:resolution_low_a lambdaber:total_rotation_deg nsls2:Mount_Type lambdaber:i_zero ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path lambdaber:description ] ;
    sh:targetClass lambdaber:AttributeGroup .

lambdaber:CTFEstimationParameters a sh:NodeShape ;
    sh:closed true ;
    sh:description "Parameters specific to CTF estimation workflows" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class nmdc:QuantityValue ;
            sh:description "Spherical aberration (Cs) value used during CTF estimation, typically specified in millimeters; may differ from instrument specification. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path lambdaber:cs_used_in_estimation ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Maximum defocus search range, typically specified in micrometers. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path lambdaber:defocus_search_max ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Accelerating voltage value used during CTF estimation, typically specified in kilovolts (kV); may differ from instrument specification. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path lambdaber:voltage_used_in_estimation ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Minimum defocus search range, typically specified in micrometers. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path lambdaber:defocus_search_min ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path lambdaber:description ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Amplitude contrast value" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path lambdaber:amplitude_contrast ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Defocus search step, typically specified in micrometers. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path lambdaber:defocus_step ] ;
    sh:targetClass lambdaber:CTFEstimationParameters .

lambdaber:ComputeResources a sh:NodeShape ;
    sh:closed true ;
    sh:description "Computational resources used" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path lambdaber:description ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Maximum memory used, typically specified in gigabytes (GB). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path lambdaber:memory_gb ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "GPU hours used, measured in hours. Data providers may specify alternative time units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path lambdaber:gpu_hours ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Storage used, typically specified in gigabytes (GB). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path lambdaber:storage_gb ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "CPU hours used, measured in hours. Data providers may specify alternative time units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path lambdaber:cpu_hours ] ;
    sh:targetClass lambdaber:ComputeResources .

lambdaber:CryoEMInstrument a sh:NodeShape ;
    sh:closed true ;
    sh:description "Cryo-EM microscope specifications" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Instrument model" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 32 ;
            sh:path lambdaber:model ],
        [ sh:datatype xsd:string ;
            sh:description "Beamline identifier at synchrotron/neutron facility" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path mmCIF:_diffrn_source.pdbx_synchrotron_beamline ],
        [ sh:datatype xsd:string ;
            sh:description "Microscope control software (e.g., SerialEM, EPU, Leginon)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path lambdaber:microscope_software ],
        [ sh:datatype xsd:boolean ;
            sh:description "Spherical aberration corrector present" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path lambdaber:cs_corrector ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Physical pixel size of the detector in micrometers" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path lambdaber:pixel_size_physical_um ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Accelerating voltage in kV" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path lambdaber:accelerating_voltage ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title for this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 36 ;
            sh:path dcterms:title ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Number of grids the autoloader can hold" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path lambdaber:autoloader_capacity ],
        [ sh:datatype xsd:string ;
            sh:description "Human-friendly facility or laboratory identifier for the instrument (e.g., 'TITAN-KRIOS-1', 'ALS-12.3.1-SIBYLS', 'RIGAKU-FR-E'). Used for local reference and equipment tracking." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path lambdaber:instrument_code ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "C2 aperture size in micrometers" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path lambdaber:c2_aperture ],
        [ sh:datatype xsd:string ;
            sh:description "Type of phase plate if present" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path lambdaber:phase_plate_type ],
        [ sh:datatype xsd:string ;
            sh:description "Energy filter manufacturer" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path lambdaber:energy_filter_make ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Objective aperture size in micrometers" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path lambdaber:objective_aperture ],
        [ sh:datatype xsd:boolean ;
            sh:description "Phase plate available" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path lambdaber:phase_plate ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Research Organization Registry (ROR) identifier for the facility" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path lambdaber:facility_ror ;
            sh:pattern "^https://ror\\.org/\\w+$" ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Electron beam spot size setting" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 22 ;
            sh:path lambdaber:spotsize ],
        [ sh:datatype xsd:string ;
            sh:description "Detector manufacturer (e.g., Gatan, ThermoFisher, DirectElectron)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path lambdaber:detector_manufacturer ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Gun lens setting" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 23 ;
            sh:path lambdaber:gunlens ],
        [ sh:description "Supported or default detector operating mode" ;
            sh:in ( "counting" "integrating" "super_resolution" "linear" "correlated_double_sampling" ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path lambdaber:detector_mode ],
        [ sh:datatype xsd:string ;
            sh:description "Physical position of detector in microscope (e.g., post-GIF, pre-column)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path lambdaber:detector_position ],
        [ sh:datatype xsd:string ;
            sh:description "Energy filter model" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path lambdaber:energy_filter_model ],
        [ sh:datatype xsd:string ;
            sh:description "Detector model (e.g., K3, Falcon 4i, DE-64)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path lambdaber:detector_model ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Spherical aberration (Cs) in millimeters" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path lambdaber:cs ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Physical pixel size in micrometers" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path lambdaber:pixel_size_physical ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Globally unique identifier as an IRI or CURIE for machine processing and external references. Used for linking data across systems and semantic web integration." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 35 ;
            sh:path lambdaber:id ],
        [ sh:description "Category distinguishing beamlines from laboratory equipment" ;
            sh:in ( CHMO:0001084 "NEUTRON_BEAMLINE" "XFEL_BEAMLINE" "ELECTRON_MICROSCOPE" "BENCHTOP_XRAY" "OPTICAL_MICROSCOPE" "SPECTROMETER" ) ;
            sh:maxCount 1 ;
            sh:order 27 ;
            sh:path lambdaber:instrument_category ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Energy filter slit width in eV" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path lambdaber:energy_filter_slit_width ],
        [ sh:datatype xsd:string ;
            sh:description "Software version" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path lambdaber:microscope_software_version ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "TEM beam diameter in micrometers" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 25 ;
            sh:path lambdaber:tem_beam_diameter ],
        [ sh:datatype xsd:date ;
            sh:description "Date of instrument installation" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path lambdaber:installation_date ],
        [ sh:description "Imaging mode for electron microscopy" ;
            sh:in ( "EFTEM" "TEM" "STEM" ) ;
            sh:maxCount 1 ;
            sh:order 24 ;
            sh:path lambdaber:imaging_mode ],
        [ sh:datatype xsd:string ;
            sh:description "A detailed textual description of this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 37 ;
            sh:path lambdaber:description ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether energy filter is present" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path lambdaber:energy_filter_present ],
        [ sh:description "Name of the research facility where the instrument is located" ;
            sh:in ( ROR:01q47ea17 ROR:02jbv0t02 ROR:05gzmn429 ROR:02550n020 ROR:05etxs293 ROR:01g5y5k24 ROR:05gvnxz63 ROR:01xjv7358 ROR:01js2sh04 ROR:01ydb3330 ROR:03vk18a84 ROR:05h992307 ROR:01qz5mb56 ROR:01qz5mb56 ) ;
            sh:maxCount 1 ;
            sh:order 28 ;
            sh:path lambdaber:facility_name ],
        [ sh:description "Generic detector technology type" ;
            sh:in ( "direct_electron_detector" "ccd" "cmos" "hybrid_photon_counting" "scintillator_coupled" "imaging_plate" "film" "ion_chamber" "sdd" "sili" "hpge" "photodiode" "maia" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path lambdaber:detector_technology ],
        [ sh:datatype xsd:string ;
            sh:description "Detector dimensions in pixels (e.g., 4096x4096, 5760x4092)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path lambdaber:detector_dimensions ],
        [ sh:description "Current operational status" ;
            sh:in ( "operational" "maintenance" "offline" "commissioning" ) ;
            sh:maxCount 1 ;
            sh:order 34 ;
            sh:path lambdaber:current_status ],
        [ sh:datatype xsd:string ;
            sh:description "Instrument manufacturer" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path lambdaber:manufacturer ] ;
    sh:targetClass lambdaber:CryoEMInstrument .

lambdaber:CryoEMPreparation a sh:NodeShape ;
    sh:closed true ;
    sh:description "Cryo-EM specific sample preparation" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Plasma treatment details" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path lambdaber:plasma_treatment ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Hole size, typically specified in micrometers (range: 0.5-5.0). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path lambdaber:hole_size ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Ethane temperature, typically specified in degrees Celsius. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path lambdaber:ethane_temperature ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Glow discharge current, typically specified in milliamperes. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path lambdaber:glow_discharge_current ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Glow discharge time, typically specified in seconds. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path lambdaber:glow_discharge_time ],
        [ sh:datatype xsd:string ;
            sh:description "Vitrification instrument used (e.g., Vitrobot)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path lambdaber:vitrification_instrument ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Chamber humidity during vitrification (range: 0-100), typically specified as a percentage. Data providers may specify as decimal fraction by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path lambdaber:humidity_percentage ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether glow discharge treatment was applied" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path lambdaber:glow_discharge_applied ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Blotting force setting" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path lambdaber:blot_force ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Chamber temperature, typically specified in degrees Celsius. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path lambdaber:chamber_temperature ],
        [ sh:description "Method used for vitrification" ;
            sh:in ( "plunge_freezing" "high_pressure_freezing" "slam_freezing" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path lambdaber:vitrification_method ],
        [ sh:datatype xsd:string ;
            sh:description "Glow discharge atmosphere (air, amylamine)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path lambdaber:glow_discharge_atmosphere ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Blotter height setting. Data providers may include unit information in the QuantityValue if needed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path lambdaber:blotter_height ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Blotter setting value. Data providers may include unit information in the QuantityValue if needed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path lambdaber:blotter_setting ],
        [ sh:datatype xsd:string ;
            sh:description "Support film type" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path lambdaber:support_film ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Blotting time, typically specified in seconds (range: 0.5-10.0). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path lambdaber:blot_time ],
        [ sh:description "Type of EM grid used" ;
            sh:in ( "c_flat" "quantifoil" "lacey_carbon" "ultrathin_carbon" "gold" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path lambdaber:grid_type ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path lambdaber:description ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Wait time before blotting, typically specified in seconds. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path lambdaber:wait_time ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Glow discharge pressure, typically specified in millibars. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path lambdaber:glow_discharge_pressure ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Volume of sample applied, typically specified in microliters. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path lambdaber:sample_applied_volume ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Number of blots applied" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path lambdaber:blot_number ],
        [ sh:description "Grid material" ;
            sh:in ( "carbon" "gold" "graphene" "silicon_nitride" ) ;
            sh:maxCount 1 ;
            sh:order 8 ;
            sh:path lambdaber:grid_material ] ;
    sh:targetClass lambdaber:CryoEMPreparation .

lambdaber:Dataset a sh:NodeShape ;
    sh:closed true ;
    sh:description "Root container holding flat entity collections and association tables. Follows relational database design patterns for structural biology data." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class lambdaber:StudyWorkflowAssociation ;
            sh:description "Links between studies and workflows (M:N)" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path lambdaber:study_workflow_associations ],
        [ sh:class lambdaber:SamplePreparation ;
            sh:description "All sample preparations" ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path lambdaber:sample_preparations ],
        [ sh:class lambdaber:ExperimentRun ;
            sh:description "All experiment runs (data collection sessions)" ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path lambdaber:experiment_runs ],
        [ sh:class lambdaber:Instrument ;
            sh:description "All instruments used across studies" ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path lambdaber:instruments ],
        [ sh:class lambdaber:WorkflowExperimentAssociation ;
            sh:description "Links between workflows and source experiments (M:N)" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path lambdaber:workflow_experiment_associations ],
        [ sh:class lambdaber:WorkflowRun ;
            sh:description "All workflow runs (computational processing)" ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path lambdaber:workflow_runs ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title for this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path dcterms:title ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Globally unique identifier as an IRI or CURIE for machine processing and external references. Used for linking data across systems and semantic web integration." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path lambdaber:id ],
        [ sh:class lambdaber:SampleDataAssociation ;
            sh:description "Links between samples and datafiles (M:N)" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path lambdaber:sample_datafile_associations ],
        [ sh:class lambdaber:Image ;
            sh:description "All images" ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path lambdaber:images ],
        [ sh:class <https://w3id.org/aims-leaf/plant/PlantSample> ;
            sh:description "All samples across all studies" ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path lambdaber:plantsamples ],
        [ sh:class <https://w3id.org/aims-leaf/plant/PlantSamplePreparation> ;
            sh:description "All plant specific sample preparations" ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path lambdaber:plant_sample_preparations ],
        [ sh:class lambdaber:Sample ;
            sh:description "All samples across all studies" ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path lambdaber:samples ],
        [ sh:class lambdaber:StudySampleAssociation ;
            sh:description "Links between studies and samples (M:N)" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path lambdaber:study_sample_associations ],
        [ sh:datatype xsd:string ;
            sh:description "A detailed textual description of this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path lambdaber:description ],
        [ sh:class lambdaber:DataFile ;
            sh:description "All data files" ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path lambdaber:data_files ],
        [ sh:class lambdaber:ExperimentSampleAssociation ;
            sh:description "Links between experiments and samples (M:N with role)" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path lambdaber:experiment_sample_associations ],
        [ sh:class lambdaber:StudyExperimentAssociation ;
            sh:description "Links between studies and experiments (M:N)" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path lambdaber:study_experiment_associations ],
        [ sh:class lambdaber:ExperimentInstrumentAssociation ;
            sh:description "Links between experiments and instruments (M:N)" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path lambdaber:experiment_instrument_associations ],
        [ sh:class lambdaber:WorkflowInputAssociation ;
            sh:description "Links between workflows and input files" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path lambdaber:workflow_input_associations ],
        [ sh:datatype xsd:string ;
            sh:description "Keywords or tags describing the dataset for search and categorization" ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path lambdaber:keywords ],
        [ sh:class lambdaber:WorkflowOutputAssociation ;
