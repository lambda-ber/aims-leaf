            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path lambdaber:id ],
        [ sh:datatype xsd:string ;
            sh:description "Name or type of fluorophore used" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path lambdaber:fluorophore ],
