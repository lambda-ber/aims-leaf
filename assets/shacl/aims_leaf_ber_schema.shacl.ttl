            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path lambdaber:checksum ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Pixel size, typically specified in Angstroms. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path lambdaber:pixel_size ],
        [ sh:datatype xsd:date ;
