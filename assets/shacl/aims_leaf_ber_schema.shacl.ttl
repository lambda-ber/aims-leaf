            sh:order 6 ;
            sh:path lambdaber:elements_measured ],
        [ sh:datatype xsd:date ;
            sh:description "File creation date" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path lambdaber:creation_date ],
        [ sh:datatype xsd:string ;
            sh:description "Reference standard used for calibration" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path lambdaber:calibration_standard ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Dwell time per pixel, typically specified in milliseconds. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path lambdaber:dwell_time ] ;
    sh:targetClass lambdaber:XRFImage .

lambdaber:XRayInstrument a sh:NodeShape ;
    sh:closed true ;
    sh:description "X-ray diffractometer or synchrotron beamline specifications" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Type of X-ray source" ;
            sh:in ( "synchrotron" "rotating_anode" "microfocus" "metal_jet" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path lambdaber:source_type ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title for this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path dcterms:title ],
        [ sh:description "Generic detector technology type" ;
            sh:in ( "direct_electron_detector" "ccd" "cmos" "hybrid_photon_counting" "scintillator_coupled" "imaging_plate" "film" "ion_chamber" "sdd" "sili" "hpge" "photodiode" "maia" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path nsls2:Detector ],
        [ sh:datatype xsd:boolean ;
            sh:description "Crystal cooling system available" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path lambdaber:crystal_cooling_capability ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Photon flux density in photons/s/mm²" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path lambdaber:flux_density ],
        [ sh:datatype xsd:string ;
            sh:description "Human-friendly facility or laboratory identifier for the instrument (e.g., 'TITAN-KRIOS-1', 'ALS-12.3.1-SIBYLS', 'RIGAKU-FR-E'). Used for local reference and equipment tracking." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path lambdaber:instrument_code ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Minimum X-ray energy in keV" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path lambdaber:energy_min ],
        [ sh:datatype xsd:string ;
            sh:description "Beamline identifier at synchrotron/neutron facility" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path mmCIF:_diffrn_source.pdbx_synchrotron_beamline ],
        [ sh:datatype xsd:string ;
            sh:description "Instrument model" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path lambdaber:model ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Minimum beam size in micrometers" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path lambdaber:beam_size_min ],
        [ sh:datatype xsd:string ;
            sh:description "Instrument manufacturer" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path lambdaber:manufacturer ],
        [ sh:datatype xsd:string ;
            sh:description "Type of monochromator" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path lambdaber:monochromator_type ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Research Organization Registry (ROR) identifier for the facility" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path lambdaber:facility_ror ;
            sh:pattern "^https://ror\\.org/\\w+$" ],
        [ sh:description "Category distinguishing beamlines from laboratory equipment" ;
            sh:in ( CHMO:0001084 "NEUTRON_BEAMLINE" "XFEL_BEAMLINE" "ELECTRON_MICROSCOPE" "BENCHTOP_XRAY" "OPTICAL_MICROSCOPE" "SPECTROMETER" ) ;
            sh:maxCount 1 ;
            sh:order 13 ;
            sh:path lambdaber:instrument_category ],
        [ sh:datatype xsd:string ;
            sh:description "Detector manufacturer (e.g., Dectris, Bruker, Rigaku, Rayonix)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path lambdaber:detector_manufacturer ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Maximum beam size in micrometers" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path lambdaber:beam_size_max ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Maximum X-ray energy in keV" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path lambdaber:energy_max ],
        [ sh:datatype xsd:date ;
            sh:description "Date of instrument installation" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path lambdaber:installation_date ],
        [ sh:description "Current operational status" ;
            sh:in ( "operational" "maintenance" "offline" "commissioning" ) ;
            sh:maxCount 1 ;
            sh:order 20 ;
            sh:path lambdaber:current_status ],
        [ sh:datatype xsd:string ;
            sh:description "A detailed textual description of this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path lambdaber:description ],
        [ sh:description "Name of the research facility where the instrument is located" ;
            sh:in ( ROR:01q47ea17 ROR:02jbv0t02 ROR:05gzmn429 ROR:02550n020 ROR:05etxs293 ROR:01g5y5k24 ROR:05gvnxz63 ROR:01xjv7358 ROR:01js2sh04 ROR:01ydb3330 ROR:03vk18a84 ROR:05h992307 ROR:01qz5mb56 ROR:01qz5mb56 ) ;
            sh:maxCount 1 ;
            sh:order 14 ;
            sh:path lambdaber:facility_name ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Globally unique identifier as an IRI or CURIE for machine processing and external references. Used for linking data across systems and semantic web integration." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path lambdaber:id ],
        [ sh:datatype xsd:string ;
            sh:description "Type of goniometer" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path lambdaber:goniometer_type ],
        [ sh:datatype xsd:string ;
            sh:description "Detector model (e.g., EIGER2 X 16M, PILATUS3 X 6M, PHOTON III)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path lambdaber:detector_model ] ;
    sh:targetClass lambdaber:XRayInstrument .

lambdaber:XRayPreparation a sh:NodeShape ;
    sh:closed true ;
    sh:description "X-ray crystallography specific preparation" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Ratio of protein to reservoir solution in drop (e.g., 1:1, 2:1)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path lambdaber:drop_ratio_protein_to_reservoir ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path lambdaber:description ],
        [ sh:datatype xsd:string ;
            sh:description "Crystal dimensions in micrometers" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path lambdaber:crystal_size_um ],
        [ sh:datatype xsd:string ;
            sh:description "Additives mixed with protein before crystallization" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path lambdaber:additives ],
        [ sh:datatype xsd:string ;
            sh:description "Cryoprotectant used" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path lambdaber:cryoprotectant ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Reservoir volume, typically specified in microliters. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path lambdaber:reservoir_volume_ul ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Total drop volume, typically specified in nanoliters. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path lambdaber:drop_volume_nl ],
        [ sh:datatype xsd:string ;
            sh:description "Description of initial crystallization hit condition" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path lambdaber:initial_hit_condition ],
        [ sh:datatype xsd:string ;
            sh:description "Dilution factor for seed stock" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path lambdaber:seed_stock_dilution ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Crystallization temperature, typically specified in degrees Celsius. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path lambdaber:temperature_c ],
        [ sh:description "Method used for crystallization" ;
            sh:in ( "vapor_diffusion_hanging" "vapor_diffusion_sitting" "batch" "microbatch" "lcp" "dialysis" "free_interface_diffusion" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path lambdaber:crystallization_method ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Loop size, typically specified in micrometers. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 22 ;
            sh:path nsls2:Loop_Size ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Protein concentration for crystallization in mg/mL" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path lambdaber:protein_concentration_mg_per_ml ],
        [ sh:datatype xsd:string ;
            sh:description "Compound used for soaking (ligand, heavy atom)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path lambdaber:soak_compound ],
        [ sh:datatype xsd:string ;
            sh:description "Buffer composition for protein solution" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path lambdaber:protein_buffer ],
        [ sh:datatype xsd:string ;
            sh:description "Type of seeding used (micro, macro, streak)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path lambdaber:seeding_type ],
        [ sh:datatype xsd:string ;
            sh:description "Name of crystallization screen used" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path lambdaber:screen_name ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Cryoprotectant concentration, typically specified as a percentage. Data providers may specify as decimal fraction by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path lambdaber:cryoprotectant_concentration ],
        [ sh:datatype xsd:string ;
            sh:description "Flash cooling protocol" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path lambdaber:flash_cooling_method ],
        [ sh:datatype xsd:string ;
            sh:description "Final optimized crystallization condition" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path lambdaber:optimized_condition ],
        [ sh:datatype xsd:string ;
            sh:description "Additional notes about crystal quality and handling" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path lambdaber:crystal_notes ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Temperature during mounting, typically specified in Kelvin. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 23 ;
            sh:path nsls2:Temperature ],
        [ sh:datatype xsd:string ;
            sh:description "Conditions for crystal soaking" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path lambdaber:soak_conditions ],
        [ sh:datatype xsd:string ;
            sh:description "Strategy used to optimize crystals" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path lambdaber:optimization_strategy ],
        [ sh:datatype xsd:string ;
            sh:description "Crystal mounting method" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path nsls2:Mount_Type ] ;
    sh:targetClass lambdaber:XRayPreparation .

<https://w3id.org/aims-leaf/functional_annotation/AggregatedProteinView> a sh:NodeShape ;
    sh:closed true ;
    sh:description "Aggregated view of all structural and functional data for a protein" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Source organism" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://w3id.org/aims-leaf/functional_annotation/organism> ],
        [ sh:class <https://w3id.org/aims-leaf/functional_annotation/ProteinProteinInteraction> ;
            sh:description "All protein-protein interactions" ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path <https://w3id.org/aims-leaf/functional_annotation/protein_interactions> ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Globally unique identifier as an IRI or CURIE for machine processing and external references. Used for linking data across systems and semantic web integration." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path lambdaber:id ],
        [ sh:datatype xsd:string ;
            sh:description "Protein name" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://w3id.org/aims-leaf/functional_annotation/protein_name> ],
        [ sh:datatype xsd:string ;
            sh:description "A detailed textual description of this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path lambdaber:description ],
        [ sh:datatype xsd:integer ;
            sh:description "NCBI taxonomy ID" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path <https://w3id.org/aims-leaf/functional_annotation/organism_id> ],
        [ sh:class <https://w3id.org/aims-leaf/functional_annotation/BiophysicalProperty> ;
            sh:description "All biophysical properties" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path <https://w3id.org/aims-leaf/functional_annotation/biophysical_properties> ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title for this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path dcterms:title ],
        [ sh:class <https://w3id.org/aims-leaf/functional_annotation/MutationEffect> ;
            sh:description "All mutation annotations" ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path <https://w3id.org/aims-leaf/functional_annotation/mutations> ],
        [ sh:class <https://w3id.org/aims-leaf/functional_annotation/ConformationalEnsemble> ;
            sh:description "Conformational ensemble data" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 12 ;
            sh:path <https://w3id.org/aims-leaf/functional_annotation/conformational_ensemble> ],
        [ sh:datatype xsd:string ;
            sh:description "All PDB entries for this protein" ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://w3id.org/aims-leaf/functional_annotation/pdb_entries> ],
        [ sh:class <https://w3id.org/aims-leaf/functional_annotation/LigandInteraction> ;
            sh:description "All ligand interactions" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path <https://w3id.org/aims-leaf/functional_annotation/ligand_interactions> ],
        [ sh:class <https://w3id.org/aims-leaf/functional_annotation/StructuralFeature> ;
            sh:description "All structural feature annotations" ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path <https://w3id.org/aims-leaf/functional_annotation/structural_features> ],
        [ sh:class <https://w3id.org/aims-leaf/functional_annotation/DatabaseCrossReference> ;
            sh:description "Database cross-references" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path <https://w3id.org/aims-leaf/functional_annotation/cross_references> ],
        [ sh:class <https://w3id.org/aims-leaf/functional_annotation/EvolutionaryConservation> ;
            sh:description "Conservation analysis" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 13 ;
            sh:path <https://w3id.org/aims-leaf/functional_annotation/evolutionary_conservation> ],
        [ sh:datatype xsd:string ;
            sh:description "UniProt accession" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://w3id.org/aims-leaf/functional_annotation/uniprot_id> ],
        [ sh:class <https://w3id.org/aims-leaf/functional_annotation/FunctionalSite> ;
            sh:description "All functional site annotations" ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path <https://w3id.org/aims-leaf/functional_annotation/functional_sites> ],
        [ sh:class <https://w3id.org/aims-leaf/functional_annotation/PostTranslationalModification> ;
            sh:description "All post-translational modifications" ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path <https://w3id.org/aims-leaf/functional_annotation/ptms> ] ;
    sh:targetClass <https://w3id.org/aims-leaf/functional_annotation/AggregatedProteinView> .

<https://w3id.org/aims-leaf/functional_annotation/ProteinAnnotation> a sh:NodeShape ;
    sh:closed true ;
    sh:description "Base class for all protein-related functional and structural annotations" ;
    sh:ignoredProperties ( <https://w3id.org/aims-leaf/functional_annotation/taxonomic_range> <https://w3id.org/aims-leaf/functional_annotation/modification_group> <https://w3id.org/aims-leaf/functional_annotation/disorder_probability> <https://w3id.org/aims-leaf/functional_annotation/interaction_evidence> <https://w3id.org/aims-leaf/functional_annotation/binding_energy> <https://w3id.org/aims-leaf/functional_annotation/clinical_significance> <https://w3id.org/aims-leaf/functional_annotation/modification_type> <https://w3id.org/aims-leaf/functional_annotation/partner_chain_id> <https://w3id.org/aims-leaf/functional_annotation/effect_on_function> <https://w3id.org/aims-leaf/functional_annotation/feature_type> <https://w3id.org/aims-leaf/functional_annotation/solvent_accessibility> <https://w3id.org/aims-leaf/functional_annotation/backbone_flexibility> <https://w3id.org/aims-leaf/functional_annotation/regulatory_role> <https://w3id.org/aims-leaf/functional_annotation/allele_frequency> <https://w3id.org/aims-leaf/functional_annotation/alignment_depth> <https://w3id.org/aims-leaf/functional_annotation/interface_area> <https://w3id.org/aims-leaf/functional_annotation/conservation_method> <https://w3id.org/aims-leaf/functional_annotation/biological_assembly> <https://w3id.org/aims-leaf/functional_annotation/enzyme> <https://w3id.org/aims-leaf/functional_annotation/effect_on_stability> <https://w3id.org/aims-leaf/functional_annotation/domain_assignment> <https://w3id.org/aims-leaf/functional_annotation/conservation_score> <https://w3id.org/aims-leaf/functional_annotation/conformational_state> <https://w3id.org/aims-leaf/functional_annotation/interface_residues> <https://w3id.org/aims-leaf/functional_annotation/site_type> <https://w3id.org/aims-leaf/functional_annotation/mutation> <https://w3id.org/aims-leaf/functional_annotation/ligand_interactions> <https://w3id.org/aims-leaf/functional_annotation/dissociation_constant> <https://w3id.org/aims-leaf/functional_annotation/functional_importance> <https://w3id.org/aims-leaf/functional_annotation/omim_id> <https://w3id.org/aims-leaf/functional_annotation/go_terms> <https://w3id.org/aims-leaf/functional_annotation/modified_residue> <https://w3id.org/aims-leaf/functional_annotation/residues> <https://w3id.org/aims-leaf/functional_annotation/conserved_residues> <https://w3id.org/aims-leaf/functional_annotation/secondary_structure> <https://w3id.org/aims-leaf/functional_annotation/mass_shift> <https://w3id.org/aims-leaf/functional_annotation/mutation_type> <https://w3id.org/aims-leaf/functional_annotation/partner_interface_residues> <https://w3id.org/aims-leaf/functional_annotation/site_name> <https://w3id.org/aims-leaf/functional_annotation/coevolved_residues> rdf:type <https://w3id.org/aims-leaf/functional_annotation/structural_motif> <https://w3id.org/aims-leaf/functional_annotation/ec_number> <https://w3id.org/aims-leaf/functional_annotation/functional_effect> <https://w3id.org/aims-leaf/functional_annotation/functional_impact_description> <https://w3id.org/aims-leaf/functional_annotation/variable_residues> <https://w3id.org/aims-leaf/functional_annotation/partner_protein_id> <https://w3id.org/aims-leaf/functional_annotation/domain_id> <https://w3id.org/aims-leaf/functional_annotation/delta_delta_g> <https://w3id.org/aims-leaf/functional_annotation/disease_association> <https://w3id.org/aims-leaf/functional_annotation/removal_enzyme> <https://w3id.org/aims-leaf/functional_annotation/complex_stability> ) ;
    sh:property [ sh:description "Type of evidence supporting this annotation" ;
            sh:in ( "experimental" "predicted" "inferred" "literature" "author_statement" "curator_inference" ) ;
            sh:maxCount 1 ;
            sh:order 5 ;
            sh:path <https://w3id.org/aims-leaf/functional_annotation/evidence_type> ],
        [ sh:datatype xsd:string ;
            sh:description "IDs of one or more publications supporting this annotation. Use PubMed IDs in the format 'PMID:XXXXXXX' or DOIs with 'DOI:' prefix." ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path <https://w3id.org/aims-leaf/functional_annotation/publication_ids> ;
            sh:pattern "^(PMID:[0-9]+|DOI:10\\.[0-9]{4,}/[-._;()/:A-Za-z0-9]+)$" ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Evidence and Conclusion Ontology (ECO) code" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path <https://w3id.org/aims-leaf/functional_annotation/evidence_code> ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Globally unique identifier as an IRI or CURIE for machine processing and external references. Used for linking data across systems and semantic web integration." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path lambdaber:id ],
        [ sh:datatype xsd:string ;
            sh:description "PDB identifier" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://w3id.org/aims-leaf/functional_annotation/pdb_entry> ;
            sh:pattern "^[0-9][A-Za-z0-9]{3}$" ],
        [ sh:datatype xsd:string ;
            sh:description "A detailed textual description of this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path lambdaber:description ],
        [ sh:description "Source database or resource that provided this annotation" ;
            sh:in ( "pdbe" "pdbe_kb" "uniprot" "pfam" "cath" "scop" "interpro" "channelsdb" "dynamine" "foldx" "p2rank" "3dligandsite" "arpeggio" "covalentizer" "depth" "elmpdb" "frustration" "kincore" "membranome" "missense3d" "mobi" "nucleos" "14_3_3_pred" "akid" "camkinet" "cansar" "credo" "klifs" "m_csm" "moondb" "pocketome" "propka" "proteins_api" "validation" "alphafold" "modbase" "swiss_model" "intact" "cosmic" "clinvar" ) ;
            sh:maxCount 1 ;
            sh:order 7 ;
            sh:path <https://w3id.org/aims-leaf/functional_annotation/source_database> ],
        [ sh:datatype xsd:string ;
            sh:description "Range of residues (e.g., '1-100', '25,27,30-35')" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path <https://w3id.org/aims-leaf/functional_annotation/residue_range> ;
            sh:pattern "^[0-9,\\-]+$" ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title for this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path dcterms:title ],
        [ sh:datatype xsd:string ;
            sh:description "Chain identifier in the PDB structure" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://w3id.org/aims-leaf/functional_annotation/chain_id> ;
            sh:pattern "^[A-Za-z0-9]+$" ],
        [ sh:datatype xsd:float ;
            sh:description "Confidence score for the annotation (range: 0-1)" ;
            sh:maxCount 1 ;
            sh:maxInclusive 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://w3id.org/aims-leaf/functional_annotation/confidence_score> ],
        [ sh:datatype xsd:string ;
            sh:description "Computational or experimental method used" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path <https://w3id.org/aims-leaf/functional_annotation/annotation_method> ],
        [ sh:datatype xsd:string ;
            sh:description "UniProt accession number" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://w3id.org/aims-leaf/functional_annotation/protein_id> ;
            sh:pattern "^[A-Z][0-9][A-Z0-9]{3}[0-9]|[A-Z][0-9][A-Z0-9]{3}[0-9]-[0-9]+$" ] ;
    sh:targetClass <https://w3id.org/aims-leaf/functional_annotation/ProteinAnnotation> .

linkml:Any a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass linkml:Any .

nmdc:AttributeValue a sh:NodeShape ;
    sh:closed false ;
    sh:description "The value for any attribute of an entity. This object can hold both the un-normalized atomic value and the structured value." ;
    sh:ignoredProperties ( lambdaber:unit_cv_id lambdaber:value lambdaber:maximum_numeric_value lambdaber:minimum_numeric_value lambdaber:unit lambdaber:numeric_value rdf:type lambdaber:value_cv_id ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Unnormalized atomic string representation, suggested syntax {number} {unit}" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path lambdaber:raw_value ],
        [ sh:class lambdaber:Attribute ;
            sh:description "The attribute being represented." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path lambdaber:attribute ] ;
    sh:targetClass nmdc:AttributeValue .

nmdc:DateTimeValue a sh:NodeShape ;
    sh:closed true ;
    sh:description "A date or date and time value." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class lambdaber:Attribute ;
            sh:description "The attribute being represented." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path lambdaber:attribute ],
        [ sh:datatype xsd:string ;
            sh:description "Unnormalized atomic string representation, suggested syntax {number} {unit}" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path lambdaber:raw_value ],
        [ sh:datatype xsd:string ;
            sh:description "The date or date/time value, expressed in ISO 8601-compatible form. Dates should be expressed as YYYY-MM-DD; times should be expressed as HH:MM:SS with optional milliseconds and an indication of the timezone." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path lambdaber:value ] ;
    sh:targetClass nmdc:DateTimeValue .

nmdc:TextValue a sh:NodeShape ;
    sh:closed true ;
    sh:description "A value described using a text string, optionally with a controlled vocabulary ID." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The text value" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path lambdaber:value ],
        [ sh:datatype xsd:string ;
            sh:description "For values in a controlled vocabulary, the CV ID for the value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path lambdaber:value_cv_id ],
        [ sh:datatype xsd:string ;
            sh:description "Unnormalized atomic string representation, suggested syntax {number} {unit}" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path lambdaber:raw_value ],
        [ sh:class lambdaber:Attribute ;
            sh:description "The attribute being represented." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path lambdaber:attribute ] ;
    sh:targetClass nmdc:TextValue .

lambdaber:DataCollectionStrategy a sh:NodeShape ;
    sh:closed true ;
    sh:description "Strategy for data collection" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class nmdc:QuantityValue ;
            sh:description "Beam center X coordinate in pixels" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path lambdaber:beam_center_x_px ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Total electron dose for cryo-EM, typically specified in electrons per Angstrom squared (e⁻/Å²). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path lambdaber:total_dose ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Total rotation range, typically specified in degrees. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path lambdaber:total_rotation_deg ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Dose per frame, typically specified in electrons per Angstrom squared (e⁻/Å²). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path lambdaber:dose_per_frame ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Data collection temperature, typically specified in Kelvin. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path lambdaber:temperature_k ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Beam size, typically specified in micrometers. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path lambdaber:beam_size_um ],
        [ sh:description "Detector operating mode used during this experiment" ;
            sh:in ( "counting" "integrating" "super_resolution" "linear" "correlated_double_sampling" ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path lambdaber:detector_mode ],
        [ sh:datatype xsd:string ;
            sh:description "Notes about data collection strategy" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path lambdaber:strategy_notes ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Detector distance, typically specified in millimeters. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path lambdaber:detector_distance_mm ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Oscillation angle per image, typically specified in degrees. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path lambdaber:oscillation_per_image_deg ],
        [ sh:datatype xsd:string ;
            sh:description "Attenuator setting used" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path lambdaber:attenuator ],
        [ sh:description "Mode of data collection" ;
            sh:in ( "counting" "super_resolution" "continuous" "oscillation" "still" "batch" "sec_saxs" "single_particle" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path lambdaber:collection_mode ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Photon flux, typically specified in photons per second. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path lambdaber:flux_photons_per_s ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "X-ray wavelength, typically specified in Angstroms. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path lambdaber:wavelength_a ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Total number of frames/images" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path lambdaber:total_frames ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Frame rate, typically specified in frames per second. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path lambdaber:frame_rate ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path lambdaber:description ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Beam center Y coordinate in pixels" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path lambdaber:beam_center_y_px ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Beam transmission, typically specified as a percentage (0-100). Data providers may specify as decimal fraction by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path lambdaber:transmission_percent ],
        [ sh:class nmdc:QuantityValue ;
