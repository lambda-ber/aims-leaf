            sh:order 1 ;
            sh:path dcterms:title ] ;
    sh:targetClass lambdaber:NamedThing .

lambdaber:OpticalImage a sh:NodeShape ;
    sh:closed true ;
    sh:description "Visible light optical microscopy or photography image" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class nmdc:QuantityValue ;
            sh:description "Electron dose in e-/Å²" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path lambdaber:dose ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Exposure time, typically specified in seconds. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path lambdaber:exposure_time ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Image height, typically specified in pixels. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path lambdaber:dimensions_y ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Optical magnification factor. Data providers may specify the unit (e.g., times, X) in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path lambdaber:magnification ],
        [ sh:datatype xsd:string ;
            sh:description "Contrast enhancement method used" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path lambdaber:contrast_method ],
        [ sh:description "Type of illumination (brightfield, darkfield, phase contrast, DIC)" ;
            sh:in ( "brightfield" "darkfield" "phase_contrast" "dic" "fluorescence" "confocal" "polarized" "oblique" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path lambdaber:illumination_type ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Globally unique identifier as an IRI or CURIE for machine processing and external references. Used for linking data across systems and semantic web integration." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path lambdaber:id ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Astigmatism value, typically specified in Angstroms. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path lambdaber:astigmatism ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Pixel size, typically specified in Angstroms. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path lambdaber:pixel_size ],
        [ sh:datatype xsd:string ;
            sh:description "A detailed textual description of this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path lambdaber:description ],
        [ sh:datatype xsd:string ;
            sh:description "Color channels present (e.g., RGB, grayscale)" ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path lambdaber:color_channels ],
        [ sh:datatype xsd:string ;
            sh:description "Image file name" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path lambdaber:file_name ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Defocus value, typically specified in micrometers. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path lambdaber:defocus ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Image width, typically specified in pixels. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path lambdaber:dimensions_x ],
        [ sh:datatype xsd:date ;
            sh:description "Date image was acquired" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path lambdaber:acquisition_date ],
        [ sh:datatype xsd:string ;
            sh:description "White balance settings" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path lambdaber:white_balance ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Numerical aperture of the objective lens. Data providers may include unit information in the QuantityValue if needed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path lambdaber:numerical_aperture ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title for this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path dcterms:title ] ;
    sh:targetClass lambdaber:OpticalImage .

lambdaber:ParticlePickingParameters a sh:NodeShape ;
    sh:closed true ;
    sh:description "Parameters specific to particle picking workflows" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Name or identifier of the deep learning model (e.g., 'resnet16', 'resnet8', 'cryolo_general'). Use this for standard pretrained models. Either model_name or model_file_path should be provided when using deep learning methods." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path lambdaber:model_name ],
        [ sh:datatype xsd:string ;
            sh:description "Source or software associated with the model (e.g., 'topaz', 'cryolo', 'warp', 'custom', 'pretrained'). Helps track model provenance and should be provided alongside model_name or model_file_path to document which software/framework the model is for." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path lambdaber:model_source ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path lambdaber:description ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Power score threshold" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path lambdaber:power_score ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Particle box size in pixels" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path lambdaber:box_size ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Normalized cross-correlation score threshold" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path lambdaber:ncc_score ],
        [ sh:datatype xsd:string ;
            sh:description "Path to deep learning model file if using a local or custom trained model file. Use this instead of model_name when pointing to a specific file on disk. Either model_name or model_file_path should be provided when using deep learning methods." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path lambdaber:model_file_path ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Picking threshold" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path lambdaber:threshold ],
        [ sh:datatype xsd:string ;
            sh:description "Method used (manual, template_matching, deep_learning, LoG, Topaz, other)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path lambdaber:picking_method ] ;
    sh:targetClass lambdaber:ParticlePickingParameters .

lambdaber:QualityMetrics a sh:NodeShape ;
    sh:closed true ;
    sh:description "Quality metrics for experiments" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class nmdc:QuantityValue ;
            sh:description "Unit cell angle alpha, typically specified in degrees. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path lambdaber:unit_cell_alpha ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Percentage of residues in favored Ramachandran regions" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 24 ;
            sh:path lambdaber:ramachandran_favored_percent ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "R-free (test set)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 23 ;
            sh:path lambdaber:r_free ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Anomalous correlation" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path lambdaber:anom_corr ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Data multiplicity (redundancy)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path lambdaber:multiplicity ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 32 ;
            sh:path lambdaber:description ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Unit cell parameter b, typically specified in Angstroms. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path lambdaber:unit_cell_b ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Signal to noise ratio" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path lambdaber:signal_to_noise ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Overall MolProbity score" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 27 ;
            sh:path lambdaber:molprobity_score ],
        [ sh:datatype xsd:string ;
            sh:description "Crystallographic space group" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path lambdaber:space_group ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Forward scattering intensity I(0)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 29 ;
            sh:path lambdaber:i_zero ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Rpim - precision-indicating merging R-factor" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path lambdaber:r_pim ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Wilson B-factor in Angstroms squared" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path lambdaber:wilson_b_factor_a2 ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Percentage of Ramachandran outliers" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 25 ;
            sh:path lambdaber:ramachandran_outliers_percent ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "MolProbity clashscore" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 26 ;
            sh:path lambdaber:clashscore ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Anomalous signal strength" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path lambdaber:anom_sig_ano ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether anomalous signal was used" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path lambdaber:anomalous_used ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Unit cell parameter c, typically specified in Angstroms. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path lambdaber:unit_cell_c ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Resolution, typically specified in Angstroms. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path lambdaber:resolution ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Completeness in highest resolution shell, typically specified as a percentage (0-100). Data providers may specify as decimal fraction by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path lambdaber:completeness_high_res_shell_percent ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Mean I/sigma(I)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path lambdaber:mean_i_over_sigma_i ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Unit cell angle beta, typically specified in degrees. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path lambdaber:unit_cell_beta ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Refinement R-factor (working set)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 22 ;
            sh:path lambdaber:r_work ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "R-factor for crystallography (deprecated, use r_work)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 31 ;
            sh:path lambdaber:r_factor ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Low resolution limit, typically specified in Angstroms. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path lambdaber:resolution_low_a ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Unit cell angle gamma, typically specified in degrees. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path lambdaber:unit_cell_gamma ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Rmerge - merge R-factor" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path lambdaber:r_merge ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Radius of gyration, typically specified in Angstroms. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 30 ;
            sh:path lambdaber:rg ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "High resolution shell limit, typically specified in Angstroms. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path lambdaber:resolution_high_shell_a ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Average B-factor in Angstroms squared" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 28 ;
            sh:path lambdaber:average_b_factor_a2 ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Half-set correlation coefficient CC(1/2)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path lambdaber:cc_half ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Data completeness, typically specified as a percentage (0-100). Data providers may specify as decimal fraction by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path lambdaber:completeness ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Unit cell parameter a, typically specified in Angstroms. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path lambdaber:unit_cell_a ] ;
    sh:targetClass lambdaber:QualityMetrics .

lambdaber:RefinementParameters a sh:NodeShape ;
    sh:closed true ;
    sh:description "Parameters specific to 3D refinement workflows" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path lambdaber:description ],
        [ sh:description "Symmetry applied (C1, Cn, Dn, T, O, I)" ;
            sh:in ( "C1" "C2" "C3" "C4" "C5" "C6" "C7" "C8" "C9" "C10" "D2" "D3" "D4" "D5" "D6" "D7" "D8" "D9" "D10" "T" "O" "I" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path lambdaber:symmetry ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Resolution at FSC=0.5, typically specified in Angstroms. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path lambdaber:resolution_0_5 ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "B-factor used for map sharpening, typically specified in Angstroms squared (Å²). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path lambdaber:map_sharpening_bfactor ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Resolution at FSC=0.143, typically specified in Angstroms. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path lambdaber:resolution_0_143 ],
        [ sh:datatype xsd:string ;
            sh:description "Strategy for data splitting" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path lambdaber:split_strategy ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether gold-standard refinement was used" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path lambdaber:gold_standard ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Pixel size, typically specified in Angstroms per pixel. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path lambdaber:pixel_size ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Box size in pixels" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path lambdaber:box_size ] ;
    sh:targetClass lambdaber:RefinementParameters .

lambdaber:TechniqueSpecificPreparation a sh:NodeShape ;
    sh:closed false ;
    sh:description "Base class for technique-specific preparation details" ;
    sh:ignoredProperties ( lambdaber:ethane_temperature lambdaber:seeding_type lambdaber:cryoprotectant_concentration nsls2:Loop_Size lambdaber:soak_conditions lambdaber:wait_time lambdaber:protein_concentration_mg_per_ml lambdaber:reservoir_volume_ul lambdaber:drop_volume_nl lambdaber:glow_discharge_applied lambdaber:screen_name lambdaber:blotter_height lambdaber:cryoprotectant lambdaber:blot_time lambdaber:optimized_condition lambdaber:temperature_c lambdaber:plasma_treatment lambdaber:crystallization_method lambdaber:chamber_temperature lambdaber:crystal_size_um lambdaber:vitrification_instrument lambdaber:additives lambdaber:crystal_notes lambdaber:blot_force lambdaber:grid_material lambdaber:vitrification_method lambdaber:soak_compound nsls2:Temperature lambdaber:humidity_percentage lambdaber:hole_size lambdaber:glow_discharge_time lambdaber:sample_applied_volume lambdaber:initial_hit_condition rdf:type lambdaber:flash_cooling_method lambdaber:blotter_setting lambdaber:blot_number lambdaber:support_film lambdaber:glow_discharge_pressure lambdaber:grid_type lambdaber:glow_discharge_atmosphere lambdaber:optimization_strategy lambdaber:protein_buffer lambdaber:glow_discharge_current lambdaber:seed_stock_dilution nsls2:Mount_Type lambdaber:drop_ratio_protein_to_reservoir ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path lambdaber:description ] ;
    sh:targetClass lambdaber:TechniqueSpecificPreparation .

lambdaber:XRFImage a sh:NodeShape ;
    sh:closed true ;
    sh:description "X-ray fluorescence (XRF) image showing elemental distribution" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "ID of the entity that owns this file" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path lambdaber:related_entity ],
        [ sh:datatype xsd:string ;
            sh:description "A detailed textual description of this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path lambdaber:description ],
        [ sh:description "Type of X-ray detector technology used" ;
            sh:in ( "direct_electron_detector" "ccd" "cmos" "hybrid_photon_counting" "scintillator_coupled" "imaging_plate" "film" "ion_chamber" "sdd" "sili" "hpge" "photodiode" "maia" ) ;
            sh:maxCount 1 ;
            sh:order 8 ;
            sh:path lambdaber:detector_technology ],
        [ sh:datatype xsd:string ;
            sh:description "Role of the file (raw, intermediate, final, diagnostic, metadata)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path lambdaber:file_role ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Photon flux, typically specified in photons per second. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path lambdaber:flux ],
        [ sh:datatype xsd:string ;
            sh:description "Elements detected and measured" ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path lambdaber:elements_measured ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Globally unique identifier as an IRI or CURIE for machine processing and external references. Used for linking data across systems and semantic web integration." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path lambdaber:id ],
        [ sh:description "File format" ;
            sh:in ( "mrc" "tiff" "ometiff" "hdf5" "star" "pdb" "mmcif" "mtz" "cbf" "cbf_zst" "img" "h5" "ascii" "thermo_raw" "zip" "mrcs" "eer" "cs" "json" "csv" "ccp4" "gz" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 14 ;
            sh:path lambdaber:file_format ],
        [ sh:datatype xsd:string ;
            sh:description "Name of the file" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path lambdaber:file_name ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Image height, typically specified in pixels. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path lambdaber:dimensions_y ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Image width, typically specified in pixels. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path lambdaber:dimensions_x ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Pixel size, typically specified in Angstroms. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path lambdaber:pixel_size ],
        [ sh:description "Type of data in the file" ;
            sh:in ( "micrograph" "diffraction" "scattering" "particles" "volume" "model" "metadata" "raw_data" "processed_data" "movie" "motion_corrected" "ctf_estimation" "particle_coordinates" "class_averages" "fsc_curve" "map_half" "validation_report" "xrf_image" "ir_image" "chemical_image" ) ;
            sh:maxCount 1 ;
            sh:order 18 ;
            sh:path lambdaber:data_type ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title for this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path dcterms:title ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "File size in bytes" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path lambdaber:file_size_bytes ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Dwell time per pixel, typically specified in milliseconds. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path lambdaber:dwell_time ],
        [ sh:description "X-ray source type (synchrotron or lab-source)" ;
            sh:in ( "synchrotron" "rotating_anode" "microfocus" "metal_jet" ) ;
            sh:maxCount 1 ;
            sh:order 7 ;
            sh:path lambdaber:source_type ],
        [ sh:datatype xsd:string ;
            sh:description "Reference standard used for calibration" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path lambdaber:calibration_standard ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "X-ray beam size, typically specified in micrometers. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path lambdaber:beam_size ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "X-ray beam energy, typically specified in kiloelectronvolts (keV). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path lambdaber:beam_energy ],
        [ sh:datatype xsd:string ;
            sh:description "Path to the file" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path lambdaber:file_path ],
        [ sh:datatype xsd:string ;
