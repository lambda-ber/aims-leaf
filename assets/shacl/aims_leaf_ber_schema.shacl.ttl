            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path <https://w3id.org/aims-leaf/plant/tissue_plant_ontology_term> ],
        [ sh:datatype xsd:string ;
            sh:description "Information about treatment involving exposure of plant or a plant part to a particular radiation regimen" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 49 ;
            sh:path <https://w3id.org/aims-leaf/plant/radiation_regimen> ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "The vertical distance (in meters) below local surface" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 23 ;
            sh:path <https://w3id.org/aims-leaf/plant/depth_meters> ],
        [ sh:datatype xsd:string ;
            sh:description "Quality control metrics for the sample" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 75 ;
            sh:path lambdaber:quality_metrics ],
        [ sh:datatype xsd:string ;
            sh:description "Information about either pedigree or other description of ancestral information" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path <https://w3id.org/aims-leaf/plant/ancestral_data> ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "The total amount or size (volume (ml), mass (g) or area (m2)) of sample collected. Separate the number and unit by a single space" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path <https://w3id.org/aims-leaf/plant/sample_size> ],
        [ sh:datatype xsd:string ;
            sh:description "Information about treatment involving an exposure to watering frequencies" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 55 ;
            sh:path <https://w3id.org/aims-leaf/plant/watering_regimen> ],
        [ sh:datatype xsd:string ;
            sh:description "Detailed description of the makeup of the plant growth medium" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path <https://w3id.org/aims-leaf/plant/growth_medium_composition> ],
        [ sh:datatype xsd:string ;
            sh:description "A detailed textual description of this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 78 ;
            sh:path lambdaber:description ],
        [ sh:datatype xsd:string ;
            sh:description "Detailed description of fertilizer application" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 42 ;
            sh:path <https://w3id.org/aims-leaf/plant/fertilizer_administration> ],
        [ sh:datatype xsd:string ;
            sh:description "The environmental material(s) immediately surrounding the sample or specimen at the time of sampling" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path <https://w3id.org/aims-leaf/plant/environmental_medium> ;
            sh:pattern ".*\\[ENVO:\\d+\\]$" ],
        [ sh:datatype xsd:string ;
            sh:description "The developmental stage of the plant from which the tissue was sampled" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path <https://w3id.org/aims-leaf/plant/developmental_stage> ],
        [ sh:datatype xsd:string ;
            sh:description "Information about treatment involving an exposure to varying degree of humidity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 48 ;
            sh:path <https://w3id.org/aims-leaf/plant/humidity_regimen> ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Globally unique identifier as an IRI or CURIE for machine processing and external references. Used for linking data across systems and semantic web integration." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 76 ;
            sh:path lambdaber:id ],
        [ sh:datatype xsd:string ;
            sh:description "Information about treatment involving use of herbicides" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 47 ;
            sh:path <https://w3id.org/aims-leaf/plant/herbicide_regimen> ],
        [ sh:datatype xsd:string ;
            sh:description "Information about treatment involving use of growth hormones" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 46 ;
            sh:path <https://w3id.org/aims-leaf/plant/growth_hormone_regimen> ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Sample purity, typically specified as a percentage (range: 0-100). Data providers may specify as decimal fraction by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 74 ;
            sh:path lambdaber:purity_percentage ],
        [ sh:datatype xsd:string ;
            sh:description "Genetic modifications of the genome of an organism, which may occur naturally by spontaneous mutation, or be introduced by some experimental means" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path <https://w3id.org/aims-leaf/plant/genetic_modification> ],
        [ sh:class lambdaber:OntologyTerm ;
            sh:description "Anatomical part or tissue (e.g., UBERON:0008945 for leaf)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 71 ;
            sh:path lambdaber:anatomy ],
        [ sh:class lambdaber:StorageConditions ;
            sh:description "Storage conditions for the sample" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 69 ;
            sh:path lambdaber:storage_conditions ],
        [ sh:class lambdaber:OntologyTerm ;
            sh:description "Cell type if applicable (e.g., CL:0000057 for fibroblast)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 72 ;
            sh:path lambdaber:cell_type ],
        [ sh:datatype xsd:float ;
            sh:description "The geographical origin of the sample as defined by latitude. The value should be reported in decimal degrees, limited to 8 decimal points, and in WGS84 system" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path <https://w3id.org/aims-leaf/plant/latitude> ],
        [ sh:datatype xsd:string ;
            sh:description "The time between inoculation with the biotic agent and sample collection, specified as days:hours:minutes" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 39 ;
            sh:path <https://w3id.org/aims-leaf/plant/time_post_inoculation> ],
        [ sh:datatype xsd:string ;
            sh:description "Information about treatment involving an exposure to light, including intensity, timing, and quality" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 50 ;
            sh:path <https://w3id.org/aims-leaf/plant/light_regimen> ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Temperature (in degrees Celsius) of the sample at time of sampling" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 25 ;
            sh:path <https://w3id.org/aims-leaf/plant/temperature> ],
        [ sh:datatype xsd:string ;
            sh:description "The number and relationship between the tissues if multiple tissue samples were combined into a single container" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://w3id.org/aims-leaf/plant/combined_tissue_description> ],
        [ sh:datatype xsd:string ;
            sh:description "Information about treatment involving use of biotic factors, such as bacteria, viruses, or fungi" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 37 ;
            sh:path <https://w3id.org/aims-leaf/plant/biotic_regimen> ],
        [ sh:datatype xsd:string ;
            sh:description "The major environmental system the sample or specimen came from. The system(s) identified should have a coarse spatial grain" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path <https://w3id.org/aims-leaf/plant/broad_scale_environmental_context> ;
            sh:pattern ".*\\[ENVO:\\d+\\]$" ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://w3id.org/aims-leaf/plant/genus> ],
        [ sh:class lambdaber:OntologyTerm ;
            sh:description "Source organism for the sample (e.g., NCBITaxon:3702 for Arabidopsis thaliana)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 70 ;
            sh:path lambdaber:organism ],
        [ sh:datatype xsd:string ;
            sh:description "Information about treatment involving use of fungicides" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 44 ;
            sh:path <https://w3id.org/aims-leaf/plant/fungicide_regimen> ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Estimated GC content of the genome of the primary species being sampled, numeric only" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path <https://w3id.org/aims-leaf/plant/gc_content_percent> ],
        [ sh:datatype xsd:integer ;
            sh:description "Integer number representing the sequential numbering of time points, applicable to samples that are part of time course experiments" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://w3id.org/aims-leaf/plant/experimental_time_point_number> ],
        [ sh:datatype xsd:string ;
            sh:description "Reference genome and annotation to be used for analysis" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path <https://w3id.org/aims-leaf/plant/reference_genome> ],
        [ sh:datatype xsd:string ;
            sh:description "Description of the time point sampled, applicable to samples that are part of time course experiments" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path <https://w3id.org/aims-leaf/plant/experimental_time_point_description> ],
        [ sh:datatype xsd:string ;
            sh:description "Culture collection name and ID from which the original plant germplasm was sourced" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path <https://w3id.org/aims-leaf/plant/germplasm_collection_id> ],
        [ sh:datatype xsd:string ;
            sh:description "Method used to prepare the sample" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 68 ;
            sh:path lambdaber:preparation_method ],
        [ sh:description "The ploidy level of the genome. For terms, please select terms listed under class ploidy (PATO:001374) of Phenotypic Quality Ontology" ;
            sh:in ( "haploid" "diploid" "triploid" "tetraploid" "pentaploid" "hexaploid" "octoploid" "allopolyploid" "autopolyploid" "aneuploid" ) ;
            sh:maxCount 1 ;
            sh:order 14 ;
            sh:path <https://w3id.org/aims-leaf/plant/ploidy> ],
        [ sh:datatype xsd:string ;
            sh:description "Information about treatment involving use of insecticides" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 43 ;
            sh:path <https://w3id.org/aims-leaf/plant/insecticide_regimen> ],
        [ sh:datatype xsd:string ;
            sh:description "Stage of the disease at the time of sample collection, e.g. inoculation, penetration, infection, growth and reproduction, dissemination of pathogen" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 62 ;
            sh:path <https://w3id.org/aims-leaf/plant/sample_disease_stage> ],
        [ sh:datatype xsd:string ;
            sh:description "Information about any mechanical damage exerted on the plant" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 58 ;
            sh:path <https://w3id.org/aims-leaf/plant/mechanical_damage> ],
        [ sh:datatype xsd:string ;
            sh:description "Type of perturbation, e.g. chemical administration, physical disturbance, etc., coupled with perturbation regimen" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 57 ;
            sh:path <https://w3id.org/aims-leaf/plant/perturbation> ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Elevation (in meters) of the sampling site as measured by the vertical distance from mean sea level" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 24 ;
            sh:path <https://w3id.org/aims-leaf/plant/elevation_meters> ],
        [ sh:datatype xsd:string ;
            sh:description "General specification of the media for growing the plants or tissue cultured samples" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path <https://w3id.org/aims-leaf/plant/growth_medium> ],
        [ sh:datatype xsd:string ;
            sh:description "Treatment involving use of mutagens" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 41 ;
            sh:path <https://w3id.org/aims-leaf/plant/chemical_mutagen> ],
        [ sh:datatype xsd:integer ;
            sh:description "Unique identifier from the NCBI taxonomy database" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path <https://w3id.org/aims-leaf/plant/ncbi_taxonomy_id> ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Estimated genome size of the primary species being sampled, between 1-100000" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path <https://w3id.org/aims-leaf/plant/estimated_genome_size_mb> ],
        [ sh:description "Type of facility where the sampled plant was grown" ;
            sh:in ( "growth_chamber" "greenhouse" "irrigated_field" "wild" "laboratory" "field" "other" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 29 ;
            sh:path <https://w3id.org/aims-leaf/plant/growth_facility> ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Molecular weight, typically specified in kilodaltons (kDa). Data providers may specify alternative units (e.g., Daltons, g/mol) by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 65 ;
            sh:path lambdaber:molecular_weight ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path <https://w3id.org/aims-leaf/plant/species> ],
        [ sh:datatype xsd:string ;
            sh:description "List of chemical compounds administered to the host or site where sampling occurred, and when" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 40 ;
            sh:path <https://w3id.org/aims-leaf/plant/chemical_administration> ],
        [ sh:datatype xsd:string ;
            sh:description "The age of the plant from which the tissue was sampled" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 32 ;
            sh:path <https://w3id.org/aims-leaf/plant/plant_age> ],
        [ sh:datatype xsd:string ;
            sh:description "Method and material used for inoculation or infiltration with a biotic agent" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 38 ;
            sh:path <https://w3id.org/aims-leaf/plant/inoculation_method> ],
        [ sh:datatype xsd:string ;
            sh:description "Information about treatment involving antibiotic administration" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 36 ;
            sh:path <https://w3id.org/aims-leaf/plant/antibiotic_regimen> ],
        [ sh:datatype xsd:string ;
            sh:description "Name or ID of the cultivar, variety, strain, or other similar designation of the primary organism being sampled" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path <https://w3id.org/aims-leaf/plant/strain_variety_cultivar> ],
        [ sh:datatype xsd:string ;
            sh:description "Information about treatment involving an exposure to varying temperatures" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 35 ;
            sh:path <https://w3id.org/aims-leaf/plant/air_temperature_regimen> ],
        [ sh:datatype xsd:string ;
            sh:description "Information about treatment involving use of salts as supplement to liquid and soil growth media" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 53 ;
            sh:path <https://w3id.org/aims-leaf/plant/salt_regimen> ],
        [ sh:datatype xsd:string ;
            sh:description "Isolate or mutant name" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path <https://w3id.org/aims-leaf/plant/isolate> ],
        [ sh:datatype xsd:string ;
            sh:description "The entity or entities which are in the sample or specimen's local vicinity and which you believe have significant causal influences on your sample or specimen" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path <https://w3id.org/aims-leaf/plant/local_environmental_context> ;
            sh:pattern ".*\\[ENVO:\\d+\\]$" ],
        [ sh:datatype xsd:float ;
            sh:description "The geographical origin of the sample as defined by longitude. The value should be reported in decimal degrees, limited to 8 decimal points, and in WGS84 system" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path <https://w3id.org/aims-leaf/plant/longitude> ],
        [ sh:datatype xsd:string ;
            sh:description "The time of sampling, either as an instance (single point in time) or interval. All valid ISO8601 formats are acceptable" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path <https://w3id.org/aims-leaf/plant/collection_date_time> ],
        [ sh:datatype xsd:string ;
            sh:description "Human-friendly laboratory identifier or facility code for the sample (e.g., 'ALS-12.3.1-SAMPLE-001', 'LAB-PROT-2024-01'). Used for local reference and tracking within laboratory workflows." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 63 ;
            sh:path lambdaber:sample_code ],
        [ sh:class lambdaber:Sample ;
            sh:description "Reference to parent sample for derivation tracking" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 73 ;
            sh:path lambdaber:parent_sample_id ],
        [ sh:description "Type of biological sample" ;
            sh:in ( "protein" "nucleic_acid" "complex" "membrane_protein" "virus" "organelle" "tissue_section" "tissue" "organism" "soil" "rock" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 64 ;
            sh:path lambdaber:sample_type ],
        [ sh:datatype xsd:string ;
            sh:description "Samples that are biological replicates should have the same group name" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://w3id.org/aims-leaf/plant/biological_replicate_sample_group_name> ],
        [ sh:datatype xsd:string ;
            sh:description "The geographical origin of the sample as defined by the country or sea name followed by specific region name" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path <https://w3id.org/aims-leaf/plant/region_locality> ],
        [ sh:datatype xsd:string ;
            sh:description "The most recent light transition before sampling" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 51 ;
            sh:path <https://w3id.org/aims-leaf/plant/last_light_transition_type> ],
        [ sh:class lambdaber:BufferComposition ;
            sh:description "Buffer composition including pH, salts, additives" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 67 ;
            sh:path lambdaber:buffer_composition ],
        [ sh:datatype xsd:string ;
            sh:description "Sex of the reproductive parts on the whole plant, e.g. pistillate, staminate, monoecious, hermaphrodite" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 60 ;
            sh:path <https://w3id.org/aims-leaf/plant/plant_sex> ],
        [ sh:datatype xsd:string ;
            sh:description "List of diseases with which the subject has been diagnosed at the time of sample collection; can include multiple diagnoses; e.g. Late wilt (Cephalosporium maydis)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 61 ;
            sh:path <https://w3id.org/aims-leaf/plant/sample_disease_staus> ],
        [ sh:datatype xsd:string ;
            sh:description "Detailed description of the organ or type of tissue sampled" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path <https://w3id.org/aims-leaf/plant/tissue> ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title for this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 77 ;
            sh:path dcterms:title ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Sample concentration, typically specified in mg/mL or µM. Data providers may specify alternative units (e.g., molar, g/L) by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 66 ;
            sh:path lambdaber:concentration ],
        [ sh:datatype xsd:string ;
            sh:description "The taxonomic name of the organism(s) found living in mutualistic, commensalistic, or parasitic symbiosis with the specific host." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 59 ;
            sh:path <https://w3id.org/aims-leaf/plant/observed_host_symbionts> ] ;
    sh:targetClass <https://w3id.org/aims-leaf/plant/PlantSample> .

<https://w3id.org/aims-leaf/plant/PlantSamplePreparation> a sh:NodeShape ;
    sh:closed true ;
    sh:description "A process that prepares a plant sample for analysis" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Growth medium used" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path lambdaber:medium ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Purity percentage by SDS-PAGE" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 49 ;
            sh:path lambdaber:purity_by_sds_page_percent ],
        [ sh:datatype xsd:string ;
            sh:description "Ratio of protease to protein" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 37 ;
            sh:path lambdaber:protease_ratio ],
        [ sh:datatype xsd:string ;
            sh:description "Ion-exchange column used" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 41 ;
            sh:path lambdaber:iex_column ],
        [ sh:description "The method employed for preserving or fixing the tissue. Use Fresh if the sample was harvested immdiately before processing. Select from the following options: [Formaldehyde, N2 Freeze, FFPE, Fresh]" ;
            sh:in ( "N2_freeze" "Formaldehyde" "FFPE" "Fresh" "Other" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path <https://w3id.org/aims-leaf/plant/sample_preservation_method> ],
        [ sh:description "Type of sample preparation" ;
            sh:in ( "cryo_em" "xray_crystallography" "saxs" "sans" "protein_expression" "protein_purification" "negative_stain" "thin_section" "thick_section" "microtome_section" "cryo_section" "ultratome_section" "whole_mount" "other_mount" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 12 ;
            sh:path lambdaber:preparation_type ],
        [ sh:datatype xsd:string ;
            sh:description "Adhesive type (glue for sections if used, tape adhesives, gel" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path <https://w3id.org/aims-leaf/plant/adhesive> ],
        [ sh:datatype xsd:string ;
            sh:description "Protease used for tag cleavage" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 36 ;
            sh:path lambdaber:protease ],
        [ sh:datatype xsd:string ;
            sh:description "type of support for sample sections (quartz, lexan, thermonox, Ge, MgF2....)" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path <https://w3id.org/aims-leaf/plant/support_type> ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Final protein concentration in mg/mL" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 47 ;
            sh:path lambdaber:final_concentration_mg_per_ml ],
        [ sh:datatype xsd:string ;
            sh:description "Size-exclusion column used" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 43 ;
            sh:path lambdaber:sec_column ],
        [ sh:datatype xsd:anyURI ;
