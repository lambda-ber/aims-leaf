            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 46 ;
            sh:path <https://w3id.org/aims-leaf/plant/growth_hormone_regimen> ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "The total amount or size (volume (ml), mass (g) or area (m2)) of sample collected. Separate the number and unit by a single space" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path <https://w3id.org/aims-leaf/plant/sample_size> ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://w3id.org/aims-leaf/plant/genus> ],
        [ sh:datatype xsd:string ;
            sh:description "Information about treatment involving an exposure to watering frequencies" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 55 ;
            sh:path <https://w3id.org/aims-leaf/plant/watering_regimen> ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Estimated genome size of the primary species being sampled, between 1-100000" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path <https://w3id.org/aims-leaf/plant/estimated_genome_size_mb> ],
        [ sh:datatype xsd:string ;
            sh:description "The time between inoculation with the biotic agent and sample collection, specified as days:hours:minutes" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 39 ;
            sh:path <https://w3id.org/aims-leaf/plant/time_post_inoculation> ],
        [ sh:datatype xsd:string ;
            sh:description "Information about treatment involving an exposure to varying degree of humidity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 48 ;
            sh:path <https://w3id.org/aims-leaf/plant/humidity_regimen> ],
        [ sh:datatype xsd:string ;
            sh:description "Information about treatment involving antibiotic administration" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 36 ;
            sh:path <https://w3id.org/aims-leaf/plant/antibiotic_regimen> ],
        [ sh:datatype xsd:string ;
            sh:description "List of diseases with which the subject has been diagnosed at the time of sample collection; can include multiple diagnoses; e.g. Late wilt (Cephalosporium maydis)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 61 ;
            sh:path <https://w3id.org/aims-leaf/plant/sample_disease_staus> ],
        [ sh:datatype xsd:string ;
            sh:description "The developmental stage of the plant from which the tissue was sampled" ;
