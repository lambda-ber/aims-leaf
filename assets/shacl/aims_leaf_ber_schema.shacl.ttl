            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path lambdaber:unit_cell_beta ] ;
    sh:targetClass lambdaber:QualityMetrics .

lambdaber:RefinementParameters a sh:NodeShape ;
    sh:closed true ;
    sh:description "Parameters specific to 3D refinement workflows" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class nmdc:QuantityValue ;
            sh:description "Box size in pixels" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path lambdaber:box_size ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Resolution at FSC=0.143, typically specified in Angstroms. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path lambdaber:resolution_0_143 ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether gold-standard refinement was used" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path lambdaber:gold_standard ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Resolution at FSC=0.5, typically specified in Angstroms. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path lambdaber:resolution_0_5 ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path lambdaber:description ],
        [ sh:datatype xsd:string ;
            sh:description "Strategy for data splitting" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path lambdaber:split_strategy ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "B-factor used for map sharpening, typically specified in Angstroms squared (Å²). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path lambdaber:map_sharpening_bfactor ],
        [ sh:description "Symmetry applied (C1, Cn, Dn, T, O, I)" ;
            sh:in ( "C1" "C2" "C3" "C4" "C5" "C6" "C7" "C8" "C9" "C10" "D2" "D3" "D4" "D5" "D6" "D7" "D8" "D9" "D10" "T" "O" "I" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path lambdaber:symmetry ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Pixel size, typically specified in Angstroms per pixel. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path lambdaber:pixel_size ] ;
    sh:targetClass lambdaber:RefinementParameters .

lambdaber:TechniqueSpecificPreparation a sh:NodeShape ;
    sh:closed false ;
    sh:description "Base class for technique-specific preparation details" ;
    sh:ignoredProperties ( lambdaber:initial_hit_condition lambdaber:vitrification_instrument lambdaber:ethane_temperature lambdaber:hole_size lambdaber:protein_concentration_mg_per_ml lambdaber:cryoprotectant_concentration lambdaber:glow_discharge_time lambdaber:crystallization_method lambdaber:cryoprotectant lambdaber:flash_cooling_method lambdaber:drop_ratio_protein_to_reservoir lambdaber:screen_name nsls2:Mount_Type lambdaber:blotter_setting lambdaber:chamber_temperature lambdaber:reservoir_volume_ul lambdaber:wait_time lambdaber:optimized_condition rdf:type lambdaber:temperature_c lambdaber:additives lambdaber:crystal_notes lambdaber:blot_time lambdaber:plasma_treatment lambdaber:support_film lambdaber:optimization_strategy lambdaber:blotter_height lambdaber:glow_discharge_pressure lambdaber:vitrification_method lambdaber:soak_conditions lambdaber:glow_discharge_atmosphere lambdaber:drop_volume_nl lambdaber:soak_compound lambdaber:grid_material lambdaber:sample_applied_volume nsls2:Temperature nsls2:Loop_Size lambdaber:blot_number lambdaber:crystal_size_um lambdaber:protein_buffer lambdaber:grid_type lambdaber:humidity_percentage lambdaber:glow_discharge_current lambdaber:seed_stock_dilution lambdaber:blot_force lambdaber:glow_discharge_applied lambdaber:seeding_type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path lambdaber:description ] ;
    sh:targetClass lambdaber:TechniqueSpecificPreparation .

lambdaber:XRFImage a sh:NodeShape ;
    sh:closed true ;
    sh:description "X-ray fluorescence (XRF) image showing elemental distribution" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Name of the file" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path lambdaber:file_name ],
        [ sh:description "Type of data in the file" ;
            sh:in ( "micrograph" "diffraction" "scattering" "particles" "volume" "model" "metadata" "raw_data" "processed_data" "movie" "motion_corrected" "ctf_estimation" "particle_coordinates" "class_averages" "fsc_curve" "map_half" "validation_report" "xrf_image" "ir_image" "chemical_image" ) ;
            sh:maxCount 1 ;
            sh:order 18 ;
            sh:path lambdaber:data_type ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Image height, typically specified in pixels. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path lambdaber:dimensions_y ],
        [ sh:datatype xsd:string ;
            sh:description "Path to the file" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path lambdaber:file_path ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Globally unique identifier as an IRI or CURIE for machine processing and external references. Used for linking data across systems and semantic web integration." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path lambdaber:id ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Pixel size, typically specified in Angstroms. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path lambdaber:pixel_size ],
        [ sh:description "X-ray source type (synchrotron or lab-source)" ;
            sh:in ( "synchrotron" "rotating_anode" "microfocus" "metal_jet" ) ;
            sh:maxCount 1 ;
            sh:order 7 ;
            sh:path lambdaber:source_type ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "File size in bytes" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path lambdaber:file_size_bytes ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "X-ray beam energy, typically specified in kiloelectronvolts (keV). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path lambdaber:beam_energy ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "X-ray beam size, typically specified in micrometers. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path lambdaber:beam_size ],
        [ sh:datatype xsd:string ;
            sh:description "Role of the file (raw, intermediate, final, diagnostic, metadata)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path lambdaber:file_role ],
        [ sh:datatype xsd:string ;
            sh:description "A detailed textual description of this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path lambdaber:description ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Image width, typically specified in pixels. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path lambdaber:dimensions_x ],
        [ sh:description "Type of X-ray detector technology used" ;
            sh:in ( "direct_electron_detector" "ccd" "cmos" "hybrid_photon_counting" "scintillator_coupled" "imaging_plate" "film" "ion_chamber" "sdd" "sili" "hpge" "photodiode" "maia" ) ;
            sh:maxCount 1 ;
            sh:order 8 ;
            sh:path lambdaber:detector_technology ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title for this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path dcterms:title ],
        [ sh:datatype xsd:string ;
            sh:description "Specific detector model used for XRF measurement" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path lambdaber:detector_model ],
        [ sh:description "File format" ;
            sh:in ( "mrc" "tiff" "ometiff" "hdf5" "star" "pdb" "mmcif" "mtz" "cbf" "cbf_zst" "img" "h5" "ascii" "thermo_raw" "zip" "mrcs" "eer" "cs" "json" "csv" "ccp4" "gz" ) ;
            sh:maxCount 1 ;
