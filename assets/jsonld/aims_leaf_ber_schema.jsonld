          "description": "seed imbibition"
        },
        {
          "text": "Stage_0.50",
          "description": "radicle emergence"
        },
        {
          "text": "Stage_0.70",
          "description": "hypocotyl and cotyledon emergence"
        },
        {
          "text": "Stage_1",
          "description": "principal growth stage - leaf development"
