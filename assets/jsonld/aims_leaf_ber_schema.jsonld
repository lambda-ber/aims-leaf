    {
      "name": "dateTimeValue__value",
      "description": "The date or date/time value, expressed in ISO 8601-compatible form. Dates should be expressed as YYYY-MM-DD; times should be expressed as HH:MM:SS with optional milliseconds and an indication of the timezone.",
      "examples": [
        {
          "value": "2025-11-09",
          "@type": "Example"
        },
        {
          "value": "2025-09-16T22:48:54Z",
          "@type": "Example"
        }
      ],
      "from_schema": "https://w3id.org/aims-leaf/types",
      "slot_uri": "https://w3id.org/aims-leaf/value",
      "alias": "value",
      "owner": "DateTimeValue",
      "domain_of": [
        "DateTimeValue"
      ],
      "range": "string",
      "required": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "proteinAnnotation__protein_id",
      "description": "UniProt accession number",
      "from_schema": "https://w3id.org/aims-leaf/functional_annotation",
      "slot_uri": "https://w3id.org/aims-leaf/functional_annotation/protein_id",
      "alias": "protein_id",
      "owner": "ProteinAnnotation",
      "domain_of": [
        "ProteinAnnotation"
      ],
      "range": "string",
      "required": true,
      "pattern": "^[A-Z][0-9][A-Z0-9]{3}[0-9]|[A-Z][0-9][A-Z0-9]{3}[0-9]-[0-9]+$",
      "@type": "SlotDefinition"
    },
    {
      "name": "proteinAnnotation__pdb_entry",
      "description": "PDB identifier",
      "from_schema": "https://w3id.org/aims-leaf/functional_annotation",
      "slot_uri": "https://w3id.org/aims-leaf/functional_annotation/pdb_entry",
      "alias": "pdb_entry",
      "owner": "ProteinAnnotation",
      "domain_of": [
        "ProteinAnnotation"
      ],
      "range": "string",
      "pattern": "^[0-9][A-Za-z0-9]{3}$",
      "@type": "SlotDefinition"
    },
    {
      "name": "proteinAnnotation__chain_id",
      "description": "Chain identifier in the PDB structure",
      "from_schema": "https://w3id.org/aims-leaf/functional_annotation",
      "slot_uri": "https://w3id.org/aims-leaf/functional_annotation/chain_id",
      "alias": "chain_id",
      "owner": "ProteinAnnotation",
      "domain_of": [
        "ProteinAnnotation"
      ],
      "range": "string",
      "pattern": "^[A-Za-z0-9]+$",
      "@type": "SlotDefinition"
    },
    {
      "name": "proteinAnnotation__residue_range",
      "description": "Range of residues (e.g., '1-100', '25,27,30-35')",
      "from_schema": "https://w3id.org/aims-leaf/functional_annotation",
      "slot_uri": "https://w3id.org/aims-leaf/functional_annotation/residue_range",
      "alias": "residue_range",
      "owner": "ProteinAnnotation",
      "domain_of": [
        "ProteinAnnotation"
      ],
      "range": "string",
      "pattern": "^[0-9,\\-]+$",
      "@type": "SlotDefinition"
    },
    {
      "name": "proteinAnnotation__confidence_score",
      "description": "Confidence score for the annotation (range: 0-1)",
      "from_schema": "https://w3id.org/aims-leaf/functional_annotation",
      "slot_uri": "https://w3id.org/aims-leaf/functional_annotation/confidence_score",
      "alias": "confidence_score",
