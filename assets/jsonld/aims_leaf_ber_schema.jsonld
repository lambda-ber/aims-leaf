          "@type": "SlotDefinition"
        },
        {
          "name": "hic_column",
          "description": "Hydrophobic interaction column used",
          "@type": "SlotDefinition"
        },
        {
          "name": "sec_column",
          "description": "Size-exclusion column used",
          "@type": "SlotDefinition"
        },
        {
