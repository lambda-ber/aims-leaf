      "domain_of": [
        "ProteinAnnotation"
      ],
      "range": "float",
      "minimum_value": 0,
      "maximum_value": 1,
      "@type": "SlotDefinition"
    },
    {
      "name": "proteinAnnotation__evidence_type",
      "description": "Type of evidence supporting this annotation",
      "from_schema": "https://w3id.org/aims-leaf/functional_annotation",
      "slot_uri": "https://w3id.org/aims-leaf/functional_annotation/evidence_type",
