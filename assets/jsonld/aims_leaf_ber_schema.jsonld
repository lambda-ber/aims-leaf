      "alias": "attribute",
      "owner": "AttributeValue",
      "domain_of": [
        "AttributeValue"
      ],
      "range": "Attribute",
      "inlined": true,
      "@type": "SlotDefinition"
    },
    {
      "name": "attributeValue__raw_value",
      "description": "Unnormalized atomic string representation, suggested syntax {number} {unit}",
      "from_schema": "https://w3id.org/aims-leaf/types",
      "slot_uri": "https://w3id.org/aims-leaf/raw_value",
      "alias": "raw_value",
