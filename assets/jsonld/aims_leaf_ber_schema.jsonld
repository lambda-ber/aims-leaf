        "sample__sample_type",
        "sample__molecular_weight",
        "sample__concentration",
        "sample__buffer_composition",
        "sample__preparation_method",
        "sample__storage_conditions",
        "sample__organism",
        "sample__anatomy",
        "sample__cell_type",
        "sample__parent_sample_id",
        "sample__purity_percentage",
        "sample__quality_metrics",
        "plantSample__biological_replicate_sample_group_name",
        "plantSample__combined_tissue_description",
        "plantSample__experimental_time_point_number",
        "plantSample__experimental_time_point_description",
        "plantSample__genus",
        "plantSample__species",
        "plantSample__strain_variety_cultivar",
        "plantSample__isolate",
        "plantSample__germplasm_collection_id",
        "plantSample__ncbi_taxonomy_id",
        "plantSample__ancestral_data",
        "plantSample__genetic_modification",
        "plantSample__estimated_genome_size_mb",
        "plantSample__gc_content_percent",
        "plantSample__ploidy",
        "plantSample__reference_genome",
        "plantSample__collection_date_time",
        "plantSample__sample_size",
        "plantSample__tissue",
        "plantSample__tissue_plant_ontology_term",
        "plantSample__region_locality",
        "plantSample__latitude",
        "plantSample__longitude",
        "plantSample__depth_meters",
        "plantSample__elevation_meters",
        "plantSample__temperature",
        "plantSample__broad_scale_environmental_context",
        "plantSample__local_environmental_context",
        "plantSample__environmental_medium",
        "plantSample__growth_facility",
        "plantSample__growth_medium",
        "plantSample__growth_medium_composition",
        "plantSample__plant_age",
        "plantSample__developmental_stage",
        "plantSample__arabadopsis_phenotype_stage",
        "plantSample__air_temperature_regimen",
        "plantSample__antibiotic_regimen",
        "plantSample__biotic_regimen",
        "plantSample__inoculation_method",
        "plantSample__time_post_inoculation",
        "plantSample__chemical_administration",
        "plantSample__chemical_mutagen",
        "plantSample__fertilizer_administration",
        "plantSample__insecticide_regimen",
        "plantSample__fungicide_regimen",
        "plantSample__gaseous_environment",
        "plantSample__growth_hormone_regimen",
        "plantSample__herbicide_regimen",
        "plantSample__humidity_regimen",
        "plantSample__radiation_regimen",
        "plantSample__light_regimen",
        "plantSample__last_light_transition_type",
        "plantSample__time_after_last_light_transition",
        "plantSample__salt_regimen",
        "plantSample__rainfall_regimen",
        "plantSample__watering_regimen",
        "plantSample__other_treatment_regimen",
        "plantSample__perturbation",
        "plantSample__mechanical_damage",
        "plantSample__observed_host_symbionts",
        "plantSample__plant_sex",
        "plantSample__sample_disease_staus",
        "plantSample__sample_disease_stage"
      ],
      "slot_usage": {},
      "attributes": [
        {
          "name": "biological_replicate_sample_group_name",
          "description": "Samples that are biological replicates should have the same group name",
          "comments": [
            "sbicolor_3d_root"
          ],
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "combined_tissue_description",
          "description": "The number and relationship between the tissues if multiple tissue samples were combined into a single container",
          "comments": [
            "6 lateral root tips from each of two plants"
          ],
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "experimental_time_point_number",
          "description": "Integer number representing the sequential numbering of time points, applicable to samples that are part of time course experiments",
          "range": "integer",
          "@type": "SlotDefinition"
        },
        {
          "name": "experimental_time_point_description",
          "description": "Description of the time point sampled, applicable to samples that are part of time course experiments",
          "comments": [
            "3 days post germination"
          ],
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "genus",
          "range": "string",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "species",
          "range": "string",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "strain_variety_cultivar",
          "description": "Name or ID of the cultivar, variety, strain, or other similar designation of the primary organism being sampled",
          "comments": [
            "RTx430"
          ],
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "isolate",
          "description": "Isolate or mutant name",
          "comments": [
            "Sb_Mut1"
          ],
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "germplasm_collection_id",
          "description": "Culture collection name and ID from which the original plant germplasm was sourced",
          "comments": [
            "ABRC CS22561"
          ],
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "ncbi_taxonomy_id",
          "description": "Unique identifier from the NCBI taxonomy database",
          "comments": [
            "4558"
          ],
          "range": "integer",
          "@type": "SlotDefinition"
        },
        {
          "name": "ancestral_data",
          "description": "Information about either pedigree or other description of ancestral information",
          "comments": [
            "Hybrid of A x B lines"
          ],
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "genetic_modification",
          "description": "Genetic modifications of the genome of an organism, which may occur naturally by spontaneous mutation, or be introduced by some experimental means",
          "comments": [
            "mlo-11 allele"
          ],
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "estimated_genome_size_mb",
          "description": "Estimated genome size of the primary species being sampled, between 1-100000",
          "comments": [
            "730 Mb"
          ],
          "range": "QuantityValue",
          "inlined": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "gc_content_percent",
          "description": "Estimated GC content of the genome of the primary species being sampled, numeric only",
          "comments": [
            "45 %"
          ],
          "range": "QuantityValue",
          "inlined": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "ploidy",
          "description": "The ploidy level of the genome. For terms, please select terms listed under class ploidy (PATO:001374) of Phenotypic Quality Ontology",
          "comments": [
            "diploid"
          ],
          "range": "PloidyTypeEnum",
          "@type": "SlotDefinition"
        },
        {
          "name": "reference_genome",
          "description": "Reference genome and annotation to be used for analysis",
          "comments": [
            "Phytozome Sorghum bicolor RTx430 v2.1"
          ],
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "collection_date_time",
          "description": "The time of sampling, either as an instance (single point in time) or interval. All valid ISO8601 formats are acceptable",
          "comments": [
            "2025-08-10T14:00:00-07:00"
          ],
          "range": "string",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "sample_size",
          "description": "The total amount or size (volume (ml), mass (g) or area (m2)) of sample collected. Separate the number and unit by a single space",
          "comments": [
            "0.45 g"
          ],
          "range": "QuantityValue",
          "inlined": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "tissue",
          "description": "Detailed description of the organ or type of tissue sampled",
          "comments": [
            "5 mm lateral root tips"
          ],
          "range": "string",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "tissue_plant_ontology_term",
          "description": "Plant ontology term corresponding to plant structure sampled; see https://planteome.org. May include multiple terms separated by semicolons",
          "comments": [
            "seedling cotyledon (PO:0025471); seedling hypocotyl (PO:0025291)"
          ],
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "region_locality",
          "description": "The geographical origin of the sample as defined by the country or sea name followed by specific region name",
          "comments": [
            "USA: California, Berkeley"
          ],
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "latitude",
          "description": "The geographical origin of the sample as defined by latitude. The value should be reported in decimal degrees, limited to 8 decimal points, and in WGS84 system",
          "comments": [
            "37.877184"
          ],
          "range": "float",
          "@type": "SlotDefinition"
        },
        {
          "name": "longitude",
          "description": "The geographical origin of the sample as defined by longitude. The value should be reported in decimal degrees, limited to 8 decimal points, and in WGS84 system",
          "comments": [
            "-122.250841"
          ],
          "range": "float",
          "@type": "SlotDefinition"
        },
        {
          "name": "depth_meters",
          "description": "The vertical distance (in meters) below local surface",
          "comments": [
            "0.1 m"
          ],
          "range": "QuantityValue",
          "inlined": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "elevation_meters",
          "description": "Elevation (in meters) of the sampling site as measured by the vertical distance from mean sea level",
          "comments": [
            "120 m"
          ],
          "range": "QuantityValue",
          "inlined": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "temperature",
          "description": "Temperature (in degrees Celsius) of the sample at time of sampling",
          "comments": [
            "22 C"
          ],
          "range": "QuantityValue",
          "inlined": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "broad_scale_environmental_context",
          "description": "The major environmental system the sample or specimen came from. The system(s) identified should have a coarse spatial grain",
          "comments": [
            "rangeland biome [ENVO:01000247]"
          ],
          "range": "string",
          "pattern": ".*\\[ENVO:\\d+\\]$",
          "@type": "SlotDefinition"
        },
        {
          "name": "local_environmental_context",
          "description": "The entity or entities which are in the sample or specimen's local vicinity and which you believe have significant causal influences on your sample or specimen",
          "comments": [
            "hillside [ENVO:01000333]"
          ],
          "range": "string",
          "pattern": ".*\\[ENVO:\\d+\\]$",
          "@type": "SlotDefinition"
        },
        {
          "name": "environmental_medium",
          "description": "The environmental material(s) immediately surrounding the sample or specimen at the time of sampling",
          "comments": [
            "bluegrass field soil [ENVO:00005789]"
          ],
          "range": "string",
          "pattern": ".*\\[ENVO:\\d+\\]$",
          "@type": "SlotDefinition"
        },
        {
          "name": "growth_facility",
          "description": "Type of facility where the sampled plant was grown",
          "comments": [
            "greenhouse"
          ],
          "range": "GrowthFacilityEnum",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "growth_medium",
          "description": "General specification of the media for growing the plants or tissue cultured samples",
          "comments": [
            "soil"
          ],
          "range": "string",
          "required": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "growth_medium_composition",
          "description": "Detailed description of the makeup of the plant growth medium",
          "comments": [
            "2:1:1 mix of coco coir, sand, and vermiculite"
          ],
          "range": "string",
          "@type": "SlotDefinition"
        },
        {
          "name": "plant_age",
          "description": "The age of the plant from which the tissue was sampled",
          "comments": [
            "3 days post germination"
          ],
          "range": "string",
