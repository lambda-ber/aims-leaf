          "range": "string",
          "@type": "SlotDefinition"
        }
      ],
      "class_uri": "https://w3id.org/nmdc/AttributeValue",
      "@type": "ClassDefinition"
    },
    {
      "name": "Attribute",
      "definition_uri": "https://w3id.org/aims-leaf/Attribute",
      "description": "A domain, measurement, attribute, property, or any descriptor for additional properties to be added to an entity. Where available, please use OBO Foundry ontologies or other controlled vocabularies for attributes; the label should be the term name from the ontology and the id should be the fully-qualified CURIE.",
      "from_schema": "https://w3id.org/aims-leaf/types",
      "slots": [
        "attribute__id",
        "attribute__label"
      ],
      "slot_usage": {},
      "attributes": [
        {
          "name": "id",
          "description": "A CURIE for the attribute, should one exist. Where available, please use OBO Foundry ontologies or other controlled vocabularies for labelling attributes; the id should be the term ID from the ontology.",
          "recommended": true,
          "@type": "SlotDefinition"
        },
        {
          "name": "label",
          "description": "Text string to describe the attribute. Where available, please use OBO Foundry ontologies or other controlled vocabularies for labelling attributes; the label should be the term name from the ontology.",
          "aliases": [
            "name",
            "title"
          ],
          "required": true,
          "@type": "SlotDefinition"
        }
      ],
      "class_uri": "https://w3id.org/aims-leaf/Attribute",
      "@type": "ClassDefinition"
    },
    {
      "name": "QuantityValue",
      "definition_uri": "https://w3id.org/aims-leaf/QuantityValue",
      "description": "A simple quantity value, representing a measurement with a numeric value and unit. This allows data providers to specify measurements in their preferred unit while enabling standardized interpretation. For example, a pixel size could be specified as 1.5 micrometers or 15 Angstroms, with the unit clearly specified.",
      "from_schema": "https://w3id.org/aims-leaf/types",
      "mappings": [
        "nmdc:QuantityValue",
        "schema:QuantityValue"
      ],
      "is_a": "AttributeValue",
