        "QuantityValue_unit",
        "unit_cv_id",
        "QuantityValue_raw_value"
      ],
      "slot_usage": {},
      "class_uri": "https://w3id.org/nmdc/QuantityValue",
      "@type": "ClassDefinition"
    },
