    skos:inScheme lambdaber: .

lambdaber:Image2D a owl:Class ;
    rdfs:label "Image2D" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty lambdaber:defocus ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty lambdaber:astigmatism ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty lambdaber:defocus ],
        [ a owl:Restriction ;
            owl:allValuesFrom lambdaber:QuantityValue ;
            owl:onProperty lambdaber:defocus ],
        [ a owl:Restriction ;
            owl:allValuesFrom lambdaber:QuantityValue ;
            owl:onProperty lambdaber:astigmatism ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty lambdaber:astigmatism ],
        lambdaber:Image ;
    skos:definition "A 2D image (micrograph, diffraction pattern)" ;
    skos:inScheme lambdaber: .

