            owl:onProperty lambdaber:defocus_step ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty lambdaber:voltage_used_in_estimation ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
