lambdaber:unit_cell_beta a owl:ObjectProperty ;
    rdfs:label "unit_cell_beta" ;
    skos:definition "Unit cell angle beta, typically specified in degrees. Data providers may specify alternative units by including the unit in the QuantityValue." ;
