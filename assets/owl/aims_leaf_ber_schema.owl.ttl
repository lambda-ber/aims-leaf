            owl:allValuesFrom lambdaber:QuantityValue ;
            owl:onProperty lambdaber:dose ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty lambdaber:file_name ],
        [ a owl:Restriction ;
            owl:allValuesFrom lambdaber:QuantityValue ;
            owl:onProperty lambdaber:pixel_size ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty lambdaber:acquisition_date ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty lambdaber:dose ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty lambdaber:acquisition_date ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty lambdaber:dose ],
        [ a owl:Restriction ;
