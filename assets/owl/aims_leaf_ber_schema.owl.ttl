<https://w3id.org/aims-leaf/plant/genus> a owl:DatatypeProperty ;
    rdfs:label "genus" ;
    skos:inScheme <https://w3id.org/aims-leaf/plant/> .

<https://w3id.org/aims-leaf/plant/germplasm_collection_id> a owl:DatatypeProperty ;
    rdfs:label "germplasm_collection_id" ;
    skos:definition "Culture collection name and ID from which the original plant germplasm was sourced" ;
