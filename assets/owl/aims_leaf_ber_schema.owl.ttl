lambdaber:AttributeValue a owl:Class ;
    rdfs:label "AttributeValue" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom lambdaber:Attribute ;
            owl:onProperty lambdaber:attribute ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty lambdaber:attribute ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty lambdaber:raw_value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty lambdaber:raw_value ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty lambdaber:attribute ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty lambdaber:raw_value ],
        linkml:ClassDefinition ;
    skos:definition "The value for any attribute of an entity. This object can hold both the un-normalized atomic value and the structured value." ;
    skos:exactMatch nmdc:AttributeValue ;
    skos:inScheme lambdaber:types .

lambdaber:Image a owl:Class ;
    rdfs:label "Image" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty lambdaber:file_name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
