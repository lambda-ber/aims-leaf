xsd:decimal a rdfs:Datatype .

lambdaber:Any a owl:Class ;
    rdfs:label "Any" ;
    rdfs:subClassOf linkml:ClassDefinition ;
    skos:exactMatch linkml:Any ;
    skos:inScheme lambdaber:types .

lambdaber:CTFEstimationParameters a owl:Class ;
    rdfs:label "CTFEstimationParameters" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom lambdaber:QuantityValue ;
            owl:onProperty lambdaber:cs_used_in_estimation ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty lambdaber:amplitude_contrast ],
        [ a owl:Restriction ;
            owl:allValuesFrom lambdaber:QuantityValue ;
            owl:onProperty lambdaber:voltage_used_in_estimation ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty lambdaber:defocus_search_min ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty lambdaber:voltage_used_in_estimation ],
        [ a owl:Restriction ;
