        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/aims-leaf/functional_annotation/binding_affinity_unit> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/aims-leaf/functional_annotation/binding_affinity_type> ],
        lambdaber:AttributeGroup ;
    skos:definition "Small molecule/ligand interactions with proteins" ;
    skos:inScheme lambdaber:functional_annotation .

