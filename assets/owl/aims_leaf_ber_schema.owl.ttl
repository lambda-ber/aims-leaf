    skos:inScheme lambdaber: .

lambdaber:microscope_software_version a owl:DatatypeProperty ;
    rdfs:label "microscope_software_version" ;
    skos:definition "Software version" ;
    skos:inScheme lambdaber: .

lambdaber:minimum_numeric_value a owl:DatatypeProperty ;
    rdfs:label "minimum_numeric_value" ;
    rdfs:subPropertyOf lambdaber:numeric_value ;
    skos:definition "The minimum value part, expressed as a number, of the quantity value when the value covers a range." ;
    skos:inScheme lambdaber:types ;
    skos:mappingRelation nmdc:minimum_numeric_value .

lambdaber:model a owl:DatatypeProperty ;
    rdfs:label "model" ;
    skos:definition "Instrument model" ;
    skos:inScheme lambdaber: .

lambdaber:model_file_path a owl:DatatypeProperty ;
    rdfs:label "model_file_path" ;
    skos:definition "Path to deep learning model file if using a local or custom trained model file. Use this instead of model_name when pointing to a specific file on disk. Either model_name or model_file_path should be provided when using deep learning methods." ;
    skos:inScheme lambdaber: .

lambdaber:model_name a owl:DatatypeProperty ;
    rdfs:label "model_name" ;
    skos:definition "Name or identifier of the deep learning model (e.g., 'resnet16', 'resnet8', 'cryolo_general'). Use this for standard pretrained models. Either model_name or model_file_path should be provided when using deep learning methods." ;
    skos:inScheme lambdaber: .

lambdaber:model_source a owl:DatatypeProperty ;
    rdfs:label "model_source" ;
    skos:definition "Source or software associated with the model (e.g., 'topaz', 'cryolo', 'warp', 'custom', 'pretrained'). Helps track model provenance and should be provided alongside model_name or model_file_path to document which software/framework the model is for." ;
    skos:inScheme lambdaber: .

lambdaber:molecular_weight a owl:ObjectProperty ;
    rdfs:label "molecular_weight" ;
    skos:definition "Molecular weight, typically specified in kilodaltons (kDa). Data providers may specify alternative units (e.g., Daltons, g/mol) by including the unit in the QuantityValue." ;
    skos:inScheme lambdaber: .

lambdaber:molprobity_score a owl:ObjectProperty ;
    rdfs:label "molprobity_score" ;
    skos:definition "Overall MolProbity score" ;
    skos:inScheme lambdaber: .

lambdaber:monochromator_type a owl:DatatypeProperty ;
    rdfs:label "monochromator_type" ;
    skos:definition "Type of monochromator" ;
    skos:inScheme lambdaber: .

lambdaber:mounting_method a owl:DatatypeProperty ;
    rdfs:label "mounting_method" ;
    skos:definition "Crystal mounting method" ;
    skos:inScheme lambdaber: ;
    skos:note "Maps to NSLS2 spreadsheet: Mount_Type" .

lambdaber:mounting_temperature a owl:ObjectProperty ;
    rdfs:label "mounting_temperature" ;
    skos:definition "Temperature during mounting, typically specified in Kelvin. Data providers may specify alternative units by including the unit in the QuantityValue." ;
    skos:inScheme lambdaber: ;
    skos:note "Maps to NSLS2 spreadsheet: Temperature" .

lambdaber:multiplicity a owl:ObjectProperty ;
    rdfs:label "multiplicity" ;
    skos:definition "Data multiplicity (redundancy)" ;
    skos:inScheme lambdaber: .

lambdaber:ncc_score a owl:ObjectProperty ;
    rdfs:label "ncc_score" ;
    skos:definition "Normalized cross-correlation score threshold" ;
    skos:inScheme lambdaber: .

lambdaber:nominal_defocus a owl:ObjectProperty ;
    rdfs:label "nominal_defocus" ;
    skos:definition "Nominal defocus value, typically specified in micrometers. Data providers may specify alternative units by including the unit in the QuantityValue." ;
    skos:inScheme lambdaber: .

lambdaber:number_of_images a owl:ObjectProperty ;
    rdfs:label "number_of_images" ;
    skos:definition "Total number of diffraction images collected" ;
    skos:inScheme lambdaber: .

lambdaber:number_of_scans a owl:ObjectProperty ;
    rdfs:label "number_of_scans" ;
    skos:definition "Number of scans averaged for the spectrum" ;
    skos:inScheme lambdaber: .

lambdaber:numerical_aperture a owl:ObjectProperty ;
    rdfs:label "numerical_aperture" ;
    skos:definition "Numerical aperture of the objective lens. Data providers may include unit information in the QuantityValue if needed." ;
    skos:inScheme lambdaber: .

lambdaber:objective_aperture a owl:ObjectProperty ;
    rdfs:label "objective_aperture" ;
    skos:definition "Objective aperture size in micrometers" ;
    skos:inScheme lambdaber: .

lambdaber:od600_at_induction a owl:ObjectProperty ;
    rdfs:label "od600_at_induction" ;
    skos:definition "Optical density at 600nm when induction was started. Data providers may include unit information in the QuantityValue if needed." ;
    skos:inScheme lambdaber: .

lambdaber:ontology a owl:DatatypeProperty ;
    rdfs:label "ontology" ;
    skos:definition "The ontology or controlled vocabulary this term comes from (e.g., GO, SO, UBERON)" ;
    skos:inScheme lambdaber: .

lambdaber:optimization_strategy a owl:DatatypeProperty ;
    rdfs:label "optimization_strategy" ;
    skos:definition "Strategy used to optimize crystals" ;
    skos:inScheme lambdaber: .

lambdaber:optimized_condition a owl:DatatypeProperty ;
    rdfs:label "optimized_condition" ;
    skos:definition "Final optimized crystallization condition" ;
    skos:inScheme lambdaber: .

lambdaber:organism a owl:ObjectProperty ;
    rdfs:label "organism" ;
    skos:definition "Source organism for the sample (e.g., NCBITaxon:3702 for Arabidopsis thaliana)" ;
    skos:inScheme lambdaber: .

lambdaber:oscillation_angle a owl:ObjectProperty ;
    rdfs:label "oscillation_angle" ;
    skos:definition "Oscillation angle per image, typically specified in degrees. Data providers may specify alternative units by including the unit in the QuantityValue." ;
    skos:exactMatch mmCIF:_diffrn_scan.angle_increment,
        nsls2:Angle_increment,
        imgCIF:_diffrn_scan_axis.angle_increment,
        ispyb:DataCollection.axisRange ;
    skos:inScheme lambdaber: .

lambdaber:oscillation_per_image_deg a owl:ObjectProperty ;
    rdfs:label "oscillation_per_image_deg" ;
    skos:definition "Oscillation angle per image, typically specified in degrees. Data providers may specify alternative units by including the unit in the QuantityValue." ;
    skos:inScheme lambdaber: .

lambdaber:output_binning a owl:ObjectProperty ;
    rdfs:label "output_binning" ;
    skos:definition "Output binning factor. This must be a positive float value (e.g., 1, 1.5, 2, 3)." ;
    skos:inScheme lambdaber: .

lambdaber:output_type a owl:ObjectProperty ;
    rdfs:label "output_type" ;
    skos:definition "Type of output from the workflow" ;
    skos:inScheme lambdaber: .

lambdaber:parameters_file_path a owl:DatatypeProperty ;
    rdfs:label "parameters_file_path" ;
    skos:definition "Path to parameters file or text of key parameters" ;
    skos:inScheme lambdaber: .

lambdaber:parent_sample_id a owl:ObjectProperty ;
    rdfs:label "parent_sample_id" ;
    skos:definition "Reference to parent sample for derivation tracking" ;
    skos:inScheme lambdaber: .

lambdaber:patch_size a owl:ObjectProperty ;
    rdfs:label "patch_size" ;
    skos:definition "Patch size for local motion correction" ;
    skos:inScheme lambdaber: .

lambdaber:ph a owl:ObjectProperty ;
    rdfs:label "ph" ;
    skos:definition "pH of the buffer (range: 0-14)" ;
    skos:inScheme lambdaber: .

lambdaber:phase_plate a owl:DatatypeProperty ;
    rdfs:label "phase_plate" ;
    skos:definition "Phase plate available" ;
    skos:inScheme lambdaber: .

lambdaber:phase_plate_type a owl:DatatypeProperty ;
    rdfs:label "phase_plate_type" ;
    skos:definition "Type of phase plate if present" ;
    skos:inScheme lambdaber: .

lambdaber:picking_method a owl:DatatypeProperty ;
    rdfs:label "picking_method" ;
    skos:definition "Method used (manual, template_matching, deep_learning, LoG, Topaz, other)" ;
    skos:inScheme lambdaber: .

lambdaber:pinhole_size a owl:ObjectProperty ;
    rdfs:label "pinhole_size" ;
    skos:definition "Pinhole size, typically specified in Airy units for confocal microscopy. Data providers may specify alternative units by including the unit in the QuantityValue." ;
    skos:inScheme lambdaber: .

lambdaber:pixel_size_calibrated a owl:ObjectProperty ;
    rdfs:label "pixel_size_calibrated" ;
    skos:definition "Calibrated pixel size for this experiment, typically specified in Angstroms (Å) per pixel. Data providers may specify alternative units by including the unit in the QuantityValue." ;
    skos:inScheme lambdaber: ;
    skos:note "For X-ray: typically mm/pixel or µm/pixel",
        "For cryo-EM: depends on magnification (Å/pixel)",
        "Physical pixel size is hardware spec stored in Instrument" .

lambdaber:pixel_size_physical a owl:ObjectProperty ;
    rdfs:label "pixel_size_physical" ;
    skos:definition "Physical pixel size in micrometers" ;
    skos:inScheme lambdaber: .

lambdaber:pixel_size_physical_um a owl:ObjectProperty ;
    rdfs:label "pixel_size_physical_um" ;
    skos:definition "Physical pixel size of the detector in micrometers" ;
    skos:inScheme lambdaber: .

lambdaber:pixel_size_unbinned a owl:ObjectProperty ;
    rdfs:label "pixel_size_unbinned" ;
    skos:definition "Unbinned pixel size, typically specified in Angstroms per pixel. Data providers may specify alternative units by including the unit in the QuantityValue." ;
    skos:inScheme lambdaber: .

lambdaber:pixel_size_x a owl:ObjectProperty ;
    rdfs:label "pixel_size_x" ;
    skos:definition "Pixel size X dimension, typically specified in micrometers (µm). Data providers may specify alternative units (e.g., Angstroms) by including the unit in the QuantityValue." ;
    skos:exactMatch nsls2:Pixel_size_x,
        imgCIF:_array_element_size.size ;
    skos:inScheme lambdaber: ;
    skos:note "imgCIF: _array_element_size.size[1]" .

lambdaber:pixel_size_y a owl:ObjectProperty ;
    rdfs:label "pixel_size_y" ;
    skos:definition "Pixel size Y dimension, typically specified in micrometers (µm). Data providers may specify alternative units (e.g., Angstroms) by including the unit in the QuantityValue." ;
    skos:exactMatch nsls2:Pixel_size_y,
        imgCIF:_array_element_size.size ;
    skos:inScheme lambdaber: ;
    skos:note "imgCIF: _array_element_size.size[2]" .

<https://w3id.org/aims-leaf/plant/adhesive> a owl:DatatypeProperty ;
    rdfs:label "adhesive" ;
    skos:definition "Adhesive type (glue for sections if used, tape adhesives, gel" ;
    skos:inScheme <https://w3id.org/aims-leaf/plant/> ;
    skos:note "superglue" .

<https://w3id.org/aims-leaf/plant/air_temperature_regimen> a owl:DatatypeProperty ;
    rdfs:label "air_temperature_regimen" ;
    skos:definition "Information about treatment involving an exposure to varying temperatures" ;
    skos:inScheme <https://w3id.org/aims-leaf/plant/> ;
    skos:note "22°C 12h day / 18°C 12h night" .

<https://w3id.org/aims-leaf/plant/ancestral_data> a owl:DatatypeProperty ;
    rdfs:label "ancestral_data" ;
    skos:definition "Information about either pedigree or other description of ancestral information" ;
    skos:inScheme <https://w3id.org/aims-leaf/plant/> ;
    skos:note "Hybrid of A x B lines" .

<https://w3id.org/aims-leaf/plant/antibiotic_regimen> a owl:DatatypeProperty ;
    rdfs:label "antibiotic_regimen" ;
    skos:definition "Information about treatment involving antibiotic administration" ;
    skos:inScheme <https://w3id.org/aims-leaf/plant/> ;
    skos:note "kanamycin 50 ug/mL added to agar plates for the full duration of growth" .

<https://w3id.org/aims-leaf/plant/arabadopsis_phenotype_stage> a owl:ObjectProperty ;
    rdfs:label "arabadopsis_phenotype_stage" ;
    skos:definition "Stage that takes into account effect of genotype & environment effects. Requires in depth knowledge about features of model organism doi: 10.1105/TPC.010011" ;
    skos:inScheme <https://w3id.org/aims-leaf/plant/> ;
    skos:note "Stage 1.04" .

<https://w3id.org/aims-leaf/plant/biological_replicate_sample_group_name> a owl:DatatypeProperty ;
    rdfs:label "biological_replicate_sample_group_name" ;
    skos:definition "Samples that are biological replicates should have the same group name" ;
    skos:inScheme <https://w3id.org/aims-leaf/plant/> ;
    skos:note "sbicolor_3d_root" .

<https://w3id.org/aims-leaf/plant/biotic_regimen> a owl:DatatypeProperty ;
    rdfs:label "biotic_regimen" ;
    skos:definition "Information about treatment involving use of biotic factors, such as bacteria, viruses, or fungi" ;
    skos:inScheme <https://w3id.org/aims-leaf/plant/> ;
    skos:note "Agrobacterium tumefaciens GV3101 infiltration" .

<https://w3id.org/aims-leaf/plant/broad_scale_environmental_context> a owl:DatatypeProperty ;
    rdfs:label "broad_scale_environmental_context" ;
    skos:definition "The major environmental system the sample or specimen came from. The system(s) identified should have a coarse spatial grain" ;
    skos:inScheme <https://w3id.org/aims-leaf/plant/> ;
    skos:note "rangeland biome [ENVO:01000247]" .

<https://w3id.org/aims-leaf/plant/chemical_administration> a owl:DatatypeProperty ;
    rdfs:label "chemical_administration" ;
    skos:definition "List of chemical compounds administered to the host or site where sampling occurred, and when" ;
    skos:inScheme <https://w3id.org/aims-leaf/plant/> ;
    skos:note "50 mM KNO3 fertilizer, weekly" .

<https://w3id.org/aims-leaf/plant/chemical_mutagen> a owl:DatatypeProperty ;
    rdfs:label "chemical_mutagen" ;
    skos:definition "Treatment involving use of mutagens" ;
    skos:inScheme <https://w3id.org/aims-leaf/plant/> ;
    skos:note "seeds soaked in EMS, 0.1%, 6h exposure before planting" .

<https://w3id.org/aims-leaf/plant/collection_date_time> a owl:DatatypeProperty ;
    rdfs:label "collection_date_time" ;
    skos:definition "The time of sampling, either as an instance (single point in time) or interval. All valid ISO8601 formats are acceptable" ;
    skos:inScheme <https://w3id.org/aims-leaf/plant/> ;
    skos:note "2025-08-10T14:00:00-07:00" .

<https://w3id.org/aims-leaf/plant/combined_tissue_description> a owl:DatatypeProperty ;
    rdfs:label "combined_tissue_description" ;
    skos:definition "The number and relationship between the tissues if multiple tissue samples were combined into a single container" ;
    skos:inScheme <https://w3id.org/aims-leaf/plant/> ;
    skos:note "6 lateral root tips from each of two plants" .

<https://w3id.org/aims-leaf/plant/depth_meters> a owl:ObjectProperty ;
    rdfs:label "depth_meters" ;
    skos:definition "The vertical distance (in meters) below local surface" ;
    skos:inScheme <https://w3id.org/aims-leaf/plant/> ;
    skos:note "0.1 m" .

<https://w3id.org/aims-leaf/plant/developmental_stage> a owl:DatatypeProperty ;
    rdfs:label "developmental_stage" ;
    skos:definition "The developmental stage of the plant from which the tissue was sampled" ;
    skos:inScheme <https://w3id.org/aims-leaf/plant/> ;
    skos:note "seedling" .

<https://w3id.org/aims-leaf/plant/elevation_meters> a owl:ObjectProperty ;
    rdfs:label "elevation_meters" ;
    skos:definition "Elevation (in meters) of the sampling site as measured by the vertical distance from mean sea level" ;
    skos:inScheme <https://w3id.org/aims-leaf/plant/> ;
    skos:note "120 m" .

<https://w3id.org/aims-leaf/plant/embedding_material> a owl:DatatypeProperty ;
    rdfs:label "embedding_material" ;
    skos:definition "Material used to stabilize for sectioning, e.g. OCT, parafin wax " ;
    skos:inScheme <https://w3id.org/aims-leaf/plant/> ;
    skos:note "OCT" .

<https://w3id.org/aims-leaf/plant/environmental_medium> a owl:DatatypeProperty ;
    rdfs:label "environmental_medium" ;
    skos:definition "The environmental material(s) immediately surrounding the sample or specimen at the time of sampling" ;
    skos:inScheme <https://w3id.org/aims-leaf/plant/> ;
    skos:note "bluegrass field soil [ENVO:00005789]" .

<https://w3id.org/aims-leaf/plant/estimated_genome_size_mb> a owl:ObjectProperty ;
    rdfs:label "estimated_genome_size_mb" ;
    skos:definition "Estimated genome size of the primary species being sampled, between 1-100000" ;
    skos:inScheme <https://w3id.org/aims-leaf/plant/> ;
    skos:note "730 Mb" .

<https://w3id.org/aims-leaf/plant/experimental_time_point_description> a owl:DatatypeProperty ;
    rdfs:label "experimental_time_point_description" ;
    skos:definition "Description of the time point sampled, applicable to samples that are part of time course experiments" ;
    skos:inScheme <https://w3id.org/aims-leaf/plant/> ;
    skos:note "3 days post germination" .

<https://w3id.org/aims-leaf/plant/experimental_time_point_number> a owl:DatatypeProperty ;
    rdfs:label "experimental_time_point_number" ;
    skos:definition "Integer number representing the sequential numbering of time points, applicable to samples that are part of time course experiments" ;
    skos:inScheme <https://w3id.org/aims-leaf/plant/> .

<https://w3id.org/aims-leaf/plant/fertilizer_administration> a owl:DatatypeProperty ;
    rdfs:label "fertilizer_administration" ;
    skos:definition "Detailed description of fertilizer application" ;
    skos:inScheme <https://w3id.org/aims-leaf/plant/> ;
    skos:note "0.5x Hoagland's solution, weekly" .

<https://w3id.org/aims-leaf/plant/fungicide_regimen> a owl:DatatypeProperty ;
    rdfs:label "fungicide_regimen" ;
    skos:definition "Information about treatment involving use of fungicides" ;
    skos:inScheme <https://w3id.org/aims-leaf/plant/> ;
    skos:note "azoxystrobin, 100 ppm, foliar spray once at weeks 2, 3, and 4" .

<https://w3id.org/aims-leaf/plant/gaseous_environment> a owl:DatatypeProperty ;
    rdfs:label "gaseous_environment" ;
    skos:definition "Use of conditions with differing gaseous environments" ;
    skos:inScheme <https://w3id.org/aims-leaf/plant/> ;
    skos:note "elevated CO2, 600 ppm, continuous" .

<https://w3id.org/aims-leaf/plant/gc_content_percent> a owl:ObjectProperty ;
    rdfs:label "gc_content_percent" ;
    skos:definition "Estimated GC content of the genome of the primary species being sampled, numeric only" ;
    skos:inScheme <https://w3id.org/aims-leaf/plant/> ;
    skos:note "45 %" .

<https://w3id.org/aims-leaf/plant/genetic_modification> a owl:DatatypeProperty ;
    rdfs:label "genetic_modification" ;
    skos:definition "Genetic modifications of the genome of an organism, which may occur naturally by spontaneous mutation, or be introduced by some experimental means" ;
    skos:inScheme <https://w3id.org/aims-leaf/plant/> ;
