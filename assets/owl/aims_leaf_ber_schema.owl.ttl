        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty lambdaber:exposure_time ],
        [ a owl:Restriction ;
            owl:allValuesFrom lambdaber:QuantityValue ;
            owl:onProperty lambdaber:dimensions_y ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty lambdaber:dimensions_x ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
