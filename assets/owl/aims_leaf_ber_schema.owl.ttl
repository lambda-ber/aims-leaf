    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/aims-leaf/ExperimentSampleRoleEnum#target> <https://w3id.org/aims-leaf/ExperimentSampleRoleEnum#buffer_blank> <https://w3id.org/aims-leaf/ExperimentSampleRoleEnum#standard> <https://w3id.org/aims-leaf/ExperimentSampleRoleEnum#size_marker> ) ;
