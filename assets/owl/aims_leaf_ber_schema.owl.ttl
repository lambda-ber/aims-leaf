    skos:definition "Unit cell angle gamma, typically specified in degrees. Data providers may specify alternative units by including the unit in the QuantityValue." ;
    skos:inScheme lambdaber: .

lambdaber:unit_cv_id a owl:DatatypeProperty ;
    rdfs:label "unit_cv_id" ;
    rdfs:range xsd:string ;
    skos:definition "The unit of the quantity, expressed as a CURIE from the Unit Ontology (e.g., UO:0000016 for micrometer)." ;
    skos:inScheme lambdaber:types .

lambdaber:value_cv_id a owl:DatatypeProperty ;
    rdfs:label "value_cv_id" ;
    rdfs:range xsd:string ;
    skos:definition "For values in a controlled vocabulary, the CV ID for the value.",
        "For values that are in a controlled vocabulary (CV), this attribute should capture the controlled vocabulary ID for the value." ;
    skos:inScheme lambdaber:types .

lambdaber:vitrification_instrument a owl:DatatypeProperty ;
    rdfs:label "vitrification_instrument" ;
    skos:definition "Vitrification instrument used (e.g., Vitrobot)" ;
    skos:inScheme lambdaber: .

lambdaber:vitrification_method a owl:ObjectProperty ;
    rdfs:label "vitrification_method" ;
    skos:definition "Method used for vitrification" ;
    skos:inScheme lambdaber: .

lambdaber:voltage_used_in_estimation a owl:ObjectProperty ;
    rdfs:label "voltage_used_in_estimation" ;
    skos:definition "Accelerating voltage value used during CTF estimation, typically specified in kilovolts (kV); may differ from instrument specification. Data providers may specify alternative units by including the unit in the QuantityValue." ;
    skos:inScheme lambdaber: .

lambdaber:voxel_size a owl:ObjectProperty ;
    rdfs:label "voxel_size" ;
    skos:definition "Voxel size, typically specified in Angstroms. Data providers may specify alternative units by including the unit in the QuantityValue." ;
    skos:inScheme lambdaber: .

lambdaber:wait_time a owl:ObjectProperty ;
    rdfs:label "wait_time" ;
    skos:definition "Wait time before blotting, typically specified in seconds. Data providers may specify alternative units by including the unit in the QuantityValue." ;
    skos:inScheme lambdaber: .

lambdaber:wash_buffer a owl:DatatypeProperty ;
    rdfs:label "wash_buffer" ;
    skos:definition "Buffer composition for washing" ;
    skos:inScheme lambdaber: .

lambdaber:wavelength a owl:ObjectProperty ;
    rdfs:label "wavelength" ;
    skos:definition "X-ray wavelength, typically specified in Angstroms (Å). Data providers may specify alternative units by including the unit in the QuantityValue." ;
    skos:exactMatch mmCIF:_diffrn_radiation_wavelength.wavelength,
        nsls2:Wavelength,
        imgCIF:_diffrn_radiation_wavelength.wavelength,
        ispyb:DataCollection.wavelength ;
    skos:inScheme lambdaber: .

lambdaber:wavelength_a a owl:ObjectProperty ;
    rdfs:label "wavelength_a" ;
    skos:definition "X-ray wavelength, typically specified in Angstroms. Data providers may specify alternative units by including the unit in the QuantityValue." ;
    skos:inScheme lambdaber: .

lambdaber:wavenumber_max a owl:ObjectProperty ;
    rdfs:label "wavenumber_max" ;
    skos:definition "Maximum wavenumber, typically specified in inverse centimeters (cm⁻¹). Data providers may specify alternative units by including the unit in the QuantityValue." ;
    skos:inScheme lambdaber: .

lambdaber:wavenumber_min a owl:ObjectProperty ;
    rdfs:label "wavenumber_min" ;
    skos:definition "Minimum wavenumber, typically specified in inverse centimeters (cm⁻¹). Data providers may specify alternative units by including the unit in the QuantityValue." ;
    skos:inScheme lambdaber: .

lambdaber:white_balance a owl:DatatypeProperty ;
    rdfs:label "white_balance" ;
    skos:definition "White balance settings" ;
    skos:inScheme lambdaber: .

lambdaber:wilson_b_factor_a2 a owl:ObjectProperty ;
    rdfs:label "wilson_b_factor_a2" ;
    skos:definition "Wilson B-factor in Angstroms squared" ;
    skos:inScheme lambdaber: .

lambdaber:workflow_code a owl:DatatypeProperty ;
    rdfs:label "workflow_code" ;
    skos:definition "Human-friendly identifier for the computational workflow run (e.g., 'MOTION-CORR-RUN-001', 'RELION-REFINE-240815'). Used for tracking processing pipelines and computational provenance." ;
    skos:inScheme lambdaber: .

lambdaber:workflow_type a owl:ObjectProperty ;
    rdfs:label "workflow_type" ;
    skos:definition "Type of processing workflow" ;
    skos:inScheme lambdaber: .

lambdaber:yield_mg a owl:ObjectProperty ;
    rdfs:label "yield_mg" ;
    skos:definition "Total yield in milligrams" ;
    skos:inScheme lambdaber: .

lambdaber:ExperimentalMethodEnum a owl:Class ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( CHMO:0000156 <https://w3id.org/aims-leaf/ExperimentalMethodEnum#neutron_diffraction> <https://w3id.org/aims-leaf/ExperimentalMethodEnum#electron_diffraction> <https://w3id.org/aims-leaf/ExperimentalMethodEnum#fiber_diffraction> ) ;
    linkml:permissible_values CHMO:0000156,
        <https://w3id.org/aims-leaf/ExperimentalMethodEnum#electron_diffraction>,
        <https://w3id.org/aims-leaf/ExperimentalMethodEnum#fiber_diffraction>,
        <https://w3id.org/aims-leaf/ExperimentalMethodEnum#neutron_diffraction> .

lambdaber:FacilityTypeEnum a owl:Class ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/aims-leaf/FacilityTypeEnum#SYNCHROTRON> <https://w3id.org/aims-leaf/FacilityTypeEnum#NEUTRON_SOURCE> <https://w3id.org/aims-leaf/FacilityTypeEnum#FREE_ELECTRON_LASER> <https://w3id.org/aims-leaf/FacilityTypeEnum#CRYOEM_CENTER> ) ;
    linkml:permissible_values <https://w3id.org/aims-leaf/FacilityTypeEnum#CRYOEM_CENTER>,
        <https://w3id.org/aims-leaf/FacilityTypeEnum#FREE_ELECTRON_LASER>,
        <https://w3id.org/aims-leaf/FacilityTypeEnum#NEUTRON_SOURCE>,
        <https://w3id.org/aims-leaf/FacilityTypeEnum#SYNCHROTRON> .

lambdaber:ImagingModeEnum a owl:Class ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/aims-leaf/ImagingModeEnum#EFTEM> <https://w3id.org/aims-leaf/ImagingModeEnum#TEM> <https://w3id.org/aims-leaf/ImagingModeEnum#STEM> ) ;
    linkml:permissible_values <https://w3id.org/aims-leaf/ImagingModeEnum#EFTEM>,
        <https://w3id.org/aims-leaf/ImagingModeEnum#STEM>,
        <https://w3id.org/aims-leaf/ImagingModeEnum#TEM> .

lambdaber:Instrument a owl:Class ;
    rdfs:label "Instrument" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty lambdaber:facility_ror ],
        [ a owl:Restriction ;
            owl:allValuesFrom lambdaber:InstrumentCategoryEnum ;
            owl:onProperty lambdaber:instrument_category ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty lambdaber:current_status ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty lambdaber:facility_name ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:anyURI [ a rdfs:Datatype ;
                                owl:onDatatype xsd:string ;
                                owl:withRestrictions ( [ xsd:pattern "^https://ror\\.org/\\w+$" ] ) ] ) ] ;
            owl:onProperty lambdaber:facility_ror ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty lambdaber:instrument_code ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty lambdaber:installation_date ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty lambdaber:instrument_category ],
        [ a owl:Restriction ;
            owl:allValuesFrom lambdaber:FacilityEnum ;
            owl:onProperty lambdaber:facility_name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty lambdaber:current_status ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty lambdaber:manufacturer ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty lambdaber:installation_date ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty lambdaber:facility_name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty lambdaber:manufacturer ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty lambdaber:model ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty lambdaber:manufacturer ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty lambdaber:instrument_code ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty lambdaber:instrument_code ],
        [ a owl:Restriction ;
            owl:allValuesFrom lambdaber:InstrumentStatusEnum ;
            owl:onProperty lambdaber:current_status ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty lambdaber:installation_date ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty lambdaber:beamline_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty lambdaber:facility_ror ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty lambdaber:beamline_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty lambdaber:model ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty lambdaber:instrument_category ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty lambdaber:model ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty lambdaber:beamline_id ],
        lambdaber:NamedThing ;
    skos:definition "An instrument used to collect data" ;
    skos:inScheme lambdaber: .

lambdaber:InstrumentRoleEnum a owl:Class ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/aims-leaf/InstrumentRoleEnum#primary> <https://w3id.org/aims-leaf/InstrumentRoleEnum#detector> <https://w3id.org/aims-leaf/InstrumentRoleEnum#sample_handler> ) ;
    linkml:permissible_values <https://w3id.org/aims-leaf/InstrumentRoleEnum#detector>,
        <https://w3id.org/aims-leaf/InstrumentRoleEnum#primary>,
        <https://w3id.org/aims-leaf/InstrumentRoleEnum#sample_handler> .

lambdaber:Study a owl:Class ;
    rdfs:label "Study" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty lambdaber:keywords ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty lambdaber:keywords ],
        lambdaber:NamedThing ;
    skos:definition "A logical grouping of related experiments investigating a research question. In the relational model, Study is lightweight - all relationships are via association tables." ;
    skos:inScheme lambdaber: .

lambdaber:VitrificationMethodEnum a owl:Class ;
    rdfs:subClassOf linkml:EnumDefinition ;
    owl:unionOf ( <https://w3id.org/aims-leaf/VitrificationMethodEnum#plunge_freezing> <https://w3id.org/aims-leaf/VitrificationMethodEnum#high_pressure_freezing> <https://w3id.org/aims-leaf/VitrificationMethodEnum#slam_freezing> ) ;
