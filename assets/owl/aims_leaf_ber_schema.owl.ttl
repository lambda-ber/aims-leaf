lambdaber:transmission a owl:ObjectProperty ;
    rdfs:label "transmission" ;
    skos:definition "X-ray beam transmission as a percentage (0-100). Data providers may specify as a decimal fraction or percentage by including the unit in the QuantityValue." ;
    skos:exactMatch ispyb:DataCollection.transmission ;
    skos:inScheme lambdaber: ;
    skos:note "Percentage of full beam intensity used" .

lambdaber:transmission_percent a owl:ObjectProperty ;
    rdfs:label "transmission_percent" ;
    skos:definition "Beam transmission, typically specified as a percentage (0-100). Data providers may specify as decimal fraction by including the unit in the QuantityValue." ;
    skos:inScheme lambdaber: .

lambdaber:undulator_gap a owl:ObjectProperty ;
    rdfs:label "undulator_gap" ;
    skos:definition "Undulator gap setting, typically specified in millimeters (mm). Data providers may specify alternative units by including the unit in the QuantityValue. Primary undulator gap for beamlines with insertion devices." ;
    skos:exactMatch ispyb:DataCollection.undulatorGap1 ;
    skos:inScheme lambdaber: ;
    skos:note "Primary undulator gap for beamlines with insertion devices" .

lambdaber:unit a owl:DatatypeProperty ;
    rdfs:label "unit" ;
    rdfs:range xsd:string ;
    skos:altLabel "scale" ;
    skos:definition "The unit of measurement. Should be taken from the UCUM unit collection or the Unit Ontology. Examples include Angstroms, micrometers, kilodaltons, degrees." ;
    skos:inScheme lambdaber:types ;
    skos:mappingRelation UO:0000000,
        <http://qudt.org/1.1/schema/qudt#unit>,
        <http://schema.org/unitCode>,
        nmdc:unit .

lambdaber:unit_cell_a a owl:ObjectProperty ;
    rdfs:label "unit_cell_a" ;
