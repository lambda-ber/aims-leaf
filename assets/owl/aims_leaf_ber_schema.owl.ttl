lambdaber:accelerating_voltage a owl:ObjectProperty ;
    rdfs:label "accelerating_voltage" ;
    skos:definition "Accelerating voltage in kV" ;
    skos:inScheme lambdaber: .

lambdaber:acquisition_date a owl:DatatypeProperty ;
    rdfs:label "acquisition_date" ;
    skos:definition "Date image was acquired" ;
    skos:inScheme lambdaber: .

lambdaber:acquisition_group a owl:DatatypeProperty ;
    rdfs:label "acquisition_group" ;
    skos:definition "Acquisition group identifier (e.g., template or area)" ;
    skos:inScheme lambdaber: .

lambdaber:acquisition_software a owl:DatatypeProperty ;
    rdfs:label "acquisition_software" ;
    skos:definition "Acquisition software used (e.g., SerialEM, EPU, Leginon)" ;
    skos:inScheme lambdaber: .

lambdaber:acquisition_software_version a owl:DatatypeProperty ;
    rdfs:label "acquisition_software_version" ;
    skos:definition "Version of acquisition software" ;
    skos:inScheme lambdaber: .

lambdaber:additional_software a owl:DatatypeProperty ;
    rdfs:label "additional_software" ;
    skos:definition "Additional software used in pipeline" ;
    skos:inScheme lambdaber: .

lambdaber:affinity_column a owl:DatatypeProperty ;
    rdfs:label "affinity_column" ;
    skos:definition "Affinity column specifications" ;
    skos:inScheme lambdaber: .

lambdaber:affinity_type a owl:DatatypeProperty ;
    rdfs:label "affinity_type" ;
    skos:definition "Type of affinity chromatography" ;
    skos:inScheme lambdaber: .

lambdaber:aggregation_assessment a owl:DatatypeProperty ;
    rdfs:label "aggregation_assessment" ;
    skos:definition "Assessment of protein aggregation state" ;
    skos:inScheme lambdaber: .

lambdaber:aliquoting a owl:DatatypeProperty ;
    rdfs:label "aliquoting" ;
    skos:definition "How the protein was aliquoted for storage" ;
    skos:inScheme lambdaber: .

lambdaber:amplitude_contrast a owl:ObjectProperty ;
    rdfs:label "amplitude_contrast" ;
    skos:definition "Amplitude contrast value" ;
    skos:inScheme lambdaber: .

lambdaber:anatomy a owl:ObjectProperty ;
    rdfs:label "anatomy" ;
    skos:definition "Anatomical part or tissue (e.g., UBERON:0008945 for leaf)" ;
    skos:inScheme lambdaber: .

lambdaber:anisotropic_correction a owl:DatatypeProperty ;
    rdfs:label "anisotropic_correction" ;
    skos:definition "Whether anisotropic motion correction was applied" ;
    skos:inScheme lambdaber: .

lambdaber:anom_corr a owl:ObjectProperty ;
    rdfs:label "anom_corr" ;
    skos:definition "Anomalous correlation" ;
    skos:inScheme lambdaber: .

lambdaber:anom_sig_ano a owl:ObjectProperty ;
    rdfs:label "anom_sig_ano" ;
    skos:definition "Anomalous signal strength" ;
    skos:inScheme lambdaber: .

lambdaber:anomalous_used a owl:DatatypeProperty ;
    rdfs:label "anomalous_used" ;
    skos:definition "Whether anomalous signal was used" ;
    skos:inScheme lambdaber: .

lambdaber:antibiotic_selection a owl:DatatypeProperty ;
    rdfs:label "antibiotic_selection" ;
    skos:definition "Antibiotic or selection agent used" ;
    skos:inScheme lambdaber: .

lambdaber:apodization_function a owl:DatatypeProperty ;
    rdfs:label "apodization_function" ;
    skos:definition "Mathematical function used for apodization" ;
    skos:inScheme lambdaber: .

lambdaber:astigmatism a owl:ObjectProperty ;
    rdfs:label "astigmatism" ;
    skos:definition "Astigmatism value, typically specified in Angstroms. Data providers may specify alternative units by including the unit in the QuantityValue." ;
    skos:inScheme lambdaber: .

lambdaber:astigmatism_target a owl:ObjectProperty ;
    rdfs:label "astigmatism_target" ;
    skos:definition "Target astigmatism in Angstroms" ;
    skos:inScheme lambdaber: .

lambdaber:attenuator a owl:DatatypeProperty ;
    rdfs:label "attenuator" ;
    skos:definition "Attenuator setting used" ;
    skos:inScheme lambdaber: .

lambdaber:attribute a owl:ObjectProperty ;
    rdfs:label "attribute" ;
    rdfs:range lambdaber:Attribute ;
    skos:definition "The attribute being represented." ;
    skos:inScheme lambdaber:types .

lambdaber:autoloader_capacity a owl:ObjectProperty ;
    rdfs:label "autoloader_capacity" ;
    skos:definition "Number of grids the autoloader can hold" ;
    skos:inScheme lambdaber: .

lambdaber:autoloader_slot a owl:DatatypeProperty ;
    rdfs:label "autoloader_slot" ;
    skos:definition "Autoloader slot identifier" ;
    skos:inScheme lambdaber: .

lambdaber:average_b_factor_a2 a owl:ObjectProperty ;
    rdfs:label "average_b_factor_a2" ;
    skos:definition "Average B-factor in Angstroms squared" ;
    skos:inScheme lambdaber: .

lambdaber:background_correction a owl:DatatypeProperty ;
    rdfs:label "background_correction" ;
    skos:definition "Method used for background correction" ;
    skos:inScheme lambdaber: .

lambdaber:beam_center_x a owl:ObjectProperty ;
    rdfs:label "beam_center_x" ;
    skos:definition "Beam center X coordinate, typically specified in pixels ([px]). Data providers may specify alternative units by including the unit in the QuantityValue." ;
    skos:exactMatch mmCIF:_diffrn_detector.beam_center_x,
        nsls2:Beam_xy_x,
        imgCIF:_diffrn_detector.beam_centre_x,
        ispyb:DataCollection.xBeam ;
    skos:inScheme lambdaber: .

lambdaber:beam_center_x_px a owl:ObjectProperty ;
    rdfs:label "beam_center_x_px" ;
    skos:definition "Beam center X coordinate in pixels" ;
    skos:inScheme lambdaber: .

lambdaber:beam_center_y a owl:ObjectProperty ;
    rdfs:label "beam_center_y" ;
    skos:definition "Beam center Y coordinate, typically specified in pixels ([px]). Data providers may specify alternative units by including the unit in the QuantityValue." ;
    skos:exactMatch mmCIF:_diffrn_detector.beam_center_y,
        nsls2:Beam_xy_y,
        imgCIF:_diffrn_detector.beam_centre_y,
        ispyb:DataCollection.yBeam ;
    skos:inScheme lambdaber: .

lambdaber:beam_center_y_px a owl:ObjectProperty ;
    rdfs:label "beam_center_y_px" ;
    skos:definition "Beam center Y coordinate in pixels" ;
    skos:inScheme lambdaber: .

lambdaber:beam_shift_x a owl:ObjectProperty ;
    rdfs:label "beam_shift_x" ;
    skos:definition "Beam shift X in microradians" ;
    skos:inScheme lambdaber: .

lambdaber:beam_shift_y a owl:ObjectProperty ;
    rdfs:label "beam_shift_y" ;
    skos:definition "Beam shift Y in microradians" ;
    skos:inScheme lambdaber: .

lambdaber:beam_size a owl:ObjectProperty ;
    rdfs:label "beam_size" ;
    skos:definition "X-ray beam size, typically specified in micrometers. Data providers may specify alternative units by including the unit in the QuantityValue." ;
    skos:inScheme lambdaber: .

lambdaber:beam_size_max a owl:ObjectProperty ;
    rdfs:label "beam_size_max" ;
    skos:definition "Maximum beam size in micrometers" ;
    skos:inScheme lambdaber: .

lambdaber:beam_size_min a owl:ObjectProperty ;
    rdfs:label "beam_size_min" ;
    skos:definition "Minimum beam size in micrometers" ;
    skos:inScheme lambdaber: .

lambdaber:beam_size_um a owl:ObjectProperty ;
    rdfs:label "beam_size_um" ;
    skos:definition "Beam size, typically specified in micrometers. Data providers may specify alternative units by including the unit in the QuantityValue." ;
    skos:inScheme lambdaber: .

lambdaber:beam_size_x a owl:ObjectProperty ;
    rdfs:label "beam_size_x" ;
    skos:definition "Beam size X dimension, typically specified in micrometers (µm). Data providers may specify alternative units (e.g., Angstroms) by including the unit in the QuantityValue." ;
    skos:inScheme lambdaber: .

lambdaber:beam_size_y a owl:ObjectProperty ;
    rdfs:label "beam_size_y" ;
    skos:definition "Beam size Y dimension, typically specified in micrometers (µm). Data providers may specify alternative units (e.g., Angstroms) by including the unit in the QuantityValue." ;
    skos:inScheme lambdaber: .

lambdaber:beamline a owl:DatatypeProperty ;
    rdfs:label "beamline" ;
    skos:definition "Beamline identifier (e.g., FMX, AMX, 12.3.1)" ;
    skos:exactMatch mmCIF:_diffrn_source.pdbx_synchrotron_beamline,
        nsls2:Beamline,
        ispyb:BLSession.beamLineName ;
