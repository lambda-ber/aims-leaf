    rdfs:label "induction_agent" ;
    skos:definition "Agent used to induce expression (e.g., IPTG, tetracycline)" ;
    skos:inScheme lambdaber: .

lambdaber:induction_temperature_c a owl:ObjectProperty ;
    rdfs:label "induction_temperature_c" ;
    skos:definition "Temperature during induction, typically specified in degrees Celsius. Data providers may specify alternative units by including the unit in the QuantityValue." ;
    skos:inScheme lambdaber: .

lambdaber:induction_time_h a owl:ObjectProperty ;
    rdfs:label "induction_time_h" ;
    skos:definition "Duration of induction, typically specified in hours. Data providers may specify alternative units (e.g., minutes, seconds) by including the unit in the QuantityValue." ;
    skos:inScheme lambdaber: .

lambdaber:initial_hit_condition a owl:DatatypeProperty ;
    rdfs:label "initial_hit_condition" ;
    skos:definition "Description of initial crystallization hit condition" ;
    skos:inScheme lambdaber: .

lambdaber:input_type a owl:ObjectProperty ;
    rdfs:label "input_type" ;
    skos:definition "Type of input for the workflow" ;
    skos:inScheme lambdaber: .

lambdaber:installation_date a owl:DatatypeProperty ;
    rdfs:label "installation_date" ;
    skos:definition "Date of instrument installation" ;
    skos:inScheme lambdaber: .

lambdaber:instrument_category a owl:ObjectProperty ;
    rdfs:label "instrument_category" ;
    skos:definition "Category distinguishing beamlines from laboratory equipment" ;
    skos:inScheme lambdaber: ;
    skos:note "Use ELECTRON_MICROSCOPE for cryo-EM instruments",
        "Use SYNCHROTRON_BEAMLINE for synchrotron beamlines" .

lambdaber:instrument_code a owl:DatatypeProperty ;
    rdfs:label "instrument_code" ;
    skos:definition "Human-friendly facility or laboratory identifier for the instrument (e.g., 'TITAN-KRIOS-1', 'ALS-12.3.1-SIBYLS', 'RIGAKU-FR-E'). Used for local reference and equipment tracking." ;
    skos:inScheme lambdaber: .

lambdaber:instrument_id a owl:ObjectProperty ;
    rdfs:label "instrument_id" ;
    skos:definition "Reference to the instrument" ;
    skos:inScheme lambdaber: .

lambdaber:ispyb_data_collection_id a owl:ObjectProperty ;
    rdfs:label "ispyb_data_collection_id" ;
    skos:definition "ISPyB DataCollection.dataCollectionId for traceability" ;
    skos:inScheme lambdaber: .

lambdaber:ispyb_session_id a owl:ObjectProperty ;
    rdfs:label "ispyb_session_id" ;
    skos:definition "ISPyB BLSession.sessionId" ;
    skos:inScheme lambdaber: .

lambdaber:laser_power a owl:ObjectProperty ;
    rdfs:label "laser_power" ;
    skos:definition "Laser power, typically specified in milliwatts. Data providers may specify alternative units by including the unit in the QuantityValue." ;
    skos:inScheme lambdaber: .

lambdaber:loop_size a owl:ObjectProperty ;
    rdfs:label "loop_size" ;
    skos:definition "Loop size, typically specified in micrometers. Data providers may specify alternative units by including the unit in the QuantityValue." ;
    skos:inScheme lambdaber: ;
    skos:note "Maps to NSLS2 spreadsheet: Loop_Size" .

lambdaber:lysis_buffer a owl:DatatypeProperty ;
    rdfs:label "lysis_buffer" ;
    skos:definition "Buffer composition for lysis" ;
    skos:inScheme lambdaber: .

lambdaber:lysis_method a owl:DatatypeProperty ;
    rdfs:label "lysis_method" ;
    skos:definition "Method used for cell lysis" ;
    skos:inScheme lambdaber: .

lambdaber:manufacturer a owl:DatatypeProperty ;
    rdfs:label "manufacturer" ;
    skos:definition "Instrument manufacturer" ;
    skos:inScheme lambdaber: .

lambdaber:map_sharpening_bfactor a owl:ObjectProperty ;
    rdfs:label "map_sharpening_bfactor" ;
    skos:definition "B-factor used for map sharpening, typically specified in Angstroms squared (Å²). Data providers may specify alternative units by including the unit in the QuantityValue." ;
    skos:inScheme lambdaber: .

lambdaber:maximum_numeric_value a owl:DatatypeProperty ;
    rdfs:label "maximum_numeric_value" ;
    rdfs:subPropertyOf lambdaber:numeric_value ;
    skos:definition "The maximum value part, expressed as a number, of the quantity value when the value covers a range." ;
    skos:inScheme lambdaber:types ;
    skos:mappingRelation nmdc:maximum_numeric_value .

lambdaber:mean_i_over_sigma_i a owl:ObjectProperty ;
    rdfs:label "mean_i_over_sigma_i" ;
    skos:definition "Mean I/sigma(I)" ;
    skos:inScheme lambdaber: .

lambdaber:medium a owl:DatatypeProperty ;
    rdfs:label "medium" ;
    skos:definition "Growth medium used" ;
    skos:inScheme lambdaber: .

lambdaber:memory_gb a owl:ObjectProperty ;
    rdfs:label "memory_gb" ;
    skos:definition "Maximum memory used, typically specified in gigabytes (GB). Data providers may specify alternative units by including the unit in the QuantityValue." ;
    skos:inScheme lambdaber: .

lambdaber:microscope_software a owl:DatatypeProperty ;
    rdfs:label "microscope_software" ;
