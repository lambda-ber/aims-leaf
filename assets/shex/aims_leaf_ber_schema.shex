<NamedThing>  (
    @<https://w3id.org/aims-leaf/functional_annotation/AggregatedProteinView> OR
    @<https://w3id.org/aims-leaf/functional_annotation/ConformationalEnsemble> OR @<DataFile> OR @<Dataset> OR @<ExperimentRun> OR
    @<Image> OR @<Instrument> OR @<https://w3id.org/aims-leaf/functional_annotation/MeasurementConditions> OR @<OntologyTerm> OR
    @<https://w3id.org/aims-leaf/functional_annotation/ProteinAnnotation> OR @<Sample> OR @<SamplePreparation> OR @<Study> OR
    @<WorkflowRun>
)

<NamedThing_struct> {
    (  $<NamedThing_tes> (  dcterms:title @linkml:String ? ;
          <description> @linkml:String ?
       ) ;
       rdf:type [ <NamedThing> ]
    )
}

<OntologyTerm> CLOSED {
    (  $<OntologyTerm_tes> (  &<NamedThing_tes> ;
          rdf:type [ <NamedThing> ] ? ;
          <terms> @<OntologyTerm> * ;
          <label> @linkml:String ? ;
          <definition> @linkml:String ? ;
          <ontology> @linkml:String ?
       ) ;
       rdf:type [ <OntologyTerm> ]
    )
}

<OpticalImage> CLOSED {
    (  $<OpticalImage_tes> (  &<Image2D_tes> ;
