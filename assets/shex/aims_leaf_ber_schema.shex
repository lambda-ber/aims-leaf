# metamodel_version: 1.7.0
# version: 0.0.0
BASE <https://w3id.org/aims-leaf/>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX linkml: <https://w3id.org/linkml/>
PREFIX nmdc: <https://w3id.org/nmdc/>
PREFIX nsls2: <https://github.com/NSLS2/BER-LAMBDA/>
PREFIX mmCIF: <http://mmcif.wwpdb.org/dictionaries/mmcif_pdbx_v50.dic/Items/>
PREFIX ROR: <https://ror.org/>
PREFIX aimsplant: <https://w3id.org/aims-leaf/plant/>


linkml:String xsd:string

linkml:Integer xsd:integer

linkml:Boolean xsd:boolean

linkml:Float xsd:float

linkml:Double xsd:double

linkml:Decimal xsd:decimal

linkml:Time xsd:time

linkml:Date xsd:date

linkml:Datetime xsd:dateTime

linkml:DateOrDatetime linkml:DateOrDatetime

linkml:Uriorcurie IRI

linkml:Curie xsd:string

linkml:Uri IRI

linkml:Ncname xsd:string

linkml:Objectidentifier IRI

linkml:Nodeidentifier NONLITERAL

linkml:Jsonpointer xsd:string

linkml:Jsonpath xsd:string

linkml:Sparqlpath xsd:string

<DecimalDegree> xsd:decimal

<https://w3id.org/aims-leaf/functional_annotation/SmilesString> xsd:string

<https://w3id.org/aims-leaf/functional_annotation/AggregatedProteinView> CLOSED {
    (  $<https://w3id.org/aims-leaf/functional_annotation/AggregatedProteinView_tes> (  &<NamedThing_tes> ;
          rdf:type [ <NamedThing> ] ? ;
          <https://w3id.org/aims-leaf/functional_annotation/uniprot_id> @linkml:String ;
          <https://w3id.org/aims-leaf/functional_annotation/protein_name> @linkml:String ;
          <https://w3id.org/aims-leaf/functional_annotation/organism> @linkml:String ? ;
          <https://w3id.org/aims-leaf/functional_annotation/organism_id> @linkml:Integer ? ;
          <https://w3id.org/aims-leaf/functional_annotation/pdb_entries> @linkml:String * ;
          <https://w3id.org/aims-leaf/functional_annotation/functional_sites>
          @<https://w3id.org/aims-leaf/functional_annotation/FunctionalSite> * ;
          <https://w3id.org/aims-leaf/functional_annotation/structural_features>
          @<https://w3id.org/aims-leaf/functional_annotation/StructuralFeature> * ;
          <https://w3id.org/aims-leaf/functional_annotation/protein_interactions>
          @<https://w3id.org/aims-leaf/functional_annotation/ProteinProteinInteraction> * ;
          <https://w3id.org/aims-leaf/functional_annotation/ligand_interactions>
          @<https://w3id.org/aims-leaf/functional_annotation/LigandInteraction> * ;
          <https://w3id.org/aims-leaf/functional_annotation/mutations>
          @<https://w3id.org/aims-leaf/functional_annotation/MutationEffect> * ;
          <https://w3id.org/aims-leaf/functional_annotation/ptms>
          @<https://w3id.org/aims-leaf/functional_annotation/PostTranslationalModification> * ;
          <https://w3id.org/aims-leaf/functional_annotation/biophysical_properties>
          @<https://w3id.org/aims-leaf/functional_annotation/BiophysicalProperty> * ;
          <https://w3id.org/aims-leaf/functional_annotation/conformational_ensemble>
          @<https://w3id.org/aims-leaf/functional_annotation/ConformationalEnsemble> ? ;
          <https://w3id.org/aims-leaf/functional_annotation/evolutionary_conservation>
          @<https://w3id.org/aims-leaf/functional_annotation/EvolutionaryConservation> ? ;
          <https://w3id.org/aims-leaf/functional_annotation/cross_references>
          @<https://w3id.org/aims-leaf/functional_annotation/DatabaseCrossReference> *
       ) ;
       rdf:type [ <https://w3id.org/aims-leaf/functional_annotation/AggregatedProteinView> ]
    )
}

<Any> CLOSED {
    (  $<Any_tes> rdf:type . * ;
       rdf:type [ linkml:Any ] ?
    )
}

<Attribute> CLOSED {
    (  $<Attribute_tes> (  <id> @linkml:String ? ;
          <label> @linkml:String
       ) ;
       rdf:type [ <Attribute> ] ?
    )
}

<AttributeGroup>  (
    @<https://w3id.org/aims-leaf/functional_annotation/BiophysicalProperty> OR @<BufferComposition> OR @<CTFEstimationParameters>
    OR @<ComputeResources> OR @<https://w3id.org/aims-leaf/functional_annotation/ConformationalState> OR @<DataCollectionStrategy>
    OR @<https://w3id.org/aims-leaf/functional_annotation/DatabaseCrossReference> OR @<ExperimentalConditions> OR @<ImageFeature>
    OR @<https://w3id.org/aims-leaf/functional_annotation/LigandInteraction> OR @<MotionCorrectionParameters> OR
    @<ParticlePickingParameters> OR @<QualityMetrics> OR @<RefinementParameters> OR @<StorageConditions> OR
    @<TechniqueSpecificPreparation>
)

<AttributeGroup_struct> {
    (  $<AttributeGroup_tes> <description> @linkml:String ? ;
       rdf:type [ <AttributeGroup> ] ?
    )
}

<AttributeValue>  (
    @<DateTimeValue> OR @<QuantityValue> OR @<TextValue>
)

<AttributeValue_struct> {
    (  $<AttributeValue_tes> (  <attribute> @<Attribute> ? ;
          <raw_value> @linkml:String ?
       ) ;
       rdf:type [ nmdc:AttributeValue ] ?
    )
}

<https://w3id.org/aims-leaf/functional_annotation/BiophysicalProperty> CLOSED {
    (  $<https://w3id.org/aims-leaf/functional_annotation/BiophysicalProperty_tes> (  &<AttributeGroup_tes> ;
          rdf:type [ <AttributeGroup> ] ? ;
          <https://w3id.org/aims-leaf/functional_annotation/property_type> [
             <https://w3id.org/aims-leaf/functional_annotation/BiophysicalPropertyEnum#melting_temperature>
             <https://w3id.org/aims-leaf/functional_annotation/BiophysicalPropertyEnum#stability>
             <https://w3id.org/aims-leaf/functional_annotation/BiophysicalPropertyEnum#folding_rate>
             <https://w3id.org/aims-leaf/functional_annotation/BiophysicalPropertyEnum#unfolding_rate>
             <https://w3id.org/aims-leaf/functional_annotation/BiophysicalPropertyEnum#aggregation_propensity>
             <https://w3id.org/aims-leaf/functional_annotation/BiophysicalPropertyEnum#solubility>
             <https://w3id.org/aims-leaf/functional_annotation/BiophysicalPropertyEnum#hydrophobicity>
             <https://w3id.org/aims-leaf/functional_annotation/BiophysicalPropertyEnum#isoelectric_point>
             <https://w3id.org/aims-leaf/functional_annotation/BiophysicalPropertyEnum#extinction_coefficient>
             <https://w3id.org/aims-leaf/functional_annotation/BiophysicalPropertyEnum#molecular_weight>
             <https://w3id.org/aims-leaf/functional_annotation/BiophysicalPropertyEnum#diffusion_coefficient>
             <https://w3id.org/aims-leaf/functional_annotation/BiophysicalPropertyEnum#sedimentation_coefficient>
             <https://w3id.org/aims-leaf/functional_annotation/BiophysicalPropertyEnum#radius_of_gyration>
             <https://w3id.org/aims-leaf/functional_annotation/BiophysicalPropertyEnum#hydrodynamic_radius> ] ;
          <https://w3id.org/aims-leaf/functional_annotation/value> @linkml:Float ;
          <https://w3id.org/aims-leaf/functional_annotation/unit> @linkml:String ;
          <https://w3id.org/aims-leaf/functional_annotation/error> @linkml:Float ? ;
          <https://w3id.org/aims-leaf/functional_annotation/measurement_conditions>
          @<https://w3id.org/aims-leaf/functional_annotation/MeasurementConditions> * ;
          <https://w3id.org/aims-leaf/functional_annotation/experimental_method> [
             <https://w3id.org/aims-leaf/functional_annotation/BiophysicalMethodEnum#differential_scanning_calorimetry>
             <https://w3id.org/aims-leaf/functional_annotation/BiophysicalMethodEnum#isothermal_titration_calorimetry>
             <https://w3id.org/aims-leaf/functional_annotation/BiophysicalMethodEnum#circular_dichroism>
             <https://w3id.org/aims-leaf/functional_annotation/BiophysicalMethodEnum#fluorescence_spectroscopy>
             <https://w3id.org/aims-leaf/functional_annotation/BiophysicalMethodEnum#surface_plasmon_resonance>
             <https://w3id.org/aims-leaf/functional_annotation/BiophysicalMethodEnum#dynamic_light_scattering>
             <https://w3id.org/aims-leaf/functional_annotation/BiophysicalMethodEnum#analytical_ultracentrifugation>
             <https://w3id.org/aims-leaf/functional_annotation/BiophysicalMethodEnum#nuclear_magnetic_resonance>
             <https://w3id.org/aims-leaf/functional_annotation/BiophysicalMethodEnum#mass_spectrometry> ] ?
       ) ;
       rdf:type [ <https://w3id.org/aims-leaf/functional_annotation/BiophysicalProperty> ] ?
    )
}

<BufferComposition> CLOSED {
    (  $<BufferComposition_tes> (  &<AttributeGroup_tes> ;
          rdf:type [ <AttributeGroup> ] ? ;
          <ph> @<QuantityValue> ? ;
          <components> @linkml:String * ;
          <additives> @linkml:String *
       ) ;
       rdf:type [ <BufferComposition> ] ?
    )
}

<ComputeResources> CLOSED {
    (  $<ComputeResources_tes> (  &<AttributeGroup_tes> ;
          rdf:type [ <AttributeGroup> ] ? ;
          <cpu_hours> @<QuantityValue> ? ;
          <gpu_hours> @<QuantityValue> ? ;
          <memory_gb> @<QuantityValue> ? ;
          <storage_gb> @<QuantityValue> ?
       ) ;
       rdf:type [ <ComputeResources> ] ?
    )
}

<https://w3id.org/aims-leaf/functional_annotation/ConformationalEnsemble> CLOSED {
    (  $<https://w3id.org/aims-leaf/functional_annotation/ConformationalEnsemble_tes> (  &<NamedThing_tes> ;
          rdf:type [ <NamedThing> ] ? ;
          <https://w3id.org/aims-leaf/functional_annotation/protein_id> @linkml:String ;
          <https://w3id.org/aims-leaf/functional_annotation/conformational_states>
          @<https://w3id.org/aims-leaf/functional_annotation/ConformationalState> * ;
          <https://w3id.org/aims-leaf/functional_annotation/clustering_method> @linkml:String ? ;
          <https://w3id.org/aims-leaf/functional_annotation/rmsd_threshold> @linkml:Float ? ;
          <https://w3id.org/aims-leaf/functional_annotation/transition_pathways> @linkml:String ? ;
          <https://w3id.org/aims-leaf/functional_annotation/energy_landscape> @linkml:String ? ;
          <https://w3id.org/aims-leaf/functional_annotation/principal_motions> @linkml:String *
       ) ;
       rdf:type [ <https://w3id.org/aims-leaf/functional_annotation/ConformationalEnsemble> ]
    )
}

<https://w3id.org/aims-leaf/functional_annotation/ConformationalState> CLOSED {
    (  $<https://w3id.org/aims-leaf/functional_annotation/ConformationalState_tes> (  &<AttributeGroup_tes> ;
          rdf:type [ <AttributeGroup> ] ? ;
          <https://w3id.org/aims-leaf/functional_annotation/state_id> @linkml:String ;
          <https://w3id.org/aims-leaf/functional_annotation/state_name> @linkml:String ? ;
          <https://w3id.org/aims-leaf/functional_annotation/pdb_entries> @linkml:String * ;
          <https://w3id.org/aims-leaf/functional_annotation/population> @linkml:Float ? ;
          <https://w3id.org/aims-leaf/functional_annotation/free_energy> @linkml:Float ? ;
          <https://w3id.org/aims-leaf/functional_annotation/rmsd_from_reference> @linkml:Float ? ;
          <https://w3id.org/aims-leaf/functional_annotation/characteristic_features> @linkml:String *
       ) ;
       rdf:type [ <https://w3id.org/aims-leaf/functional_annotation/ConformationalState> ] ?
    )
}

<CryoEMInstrument> CLOSED {
    (  $<CryoEMInstrument_tes> (  &<Instrument_tes> ;
          rdf:type [ <Instrument> ] ? ;
          <accelerating_voltage> @<QuantityValue> ? ;
          <cs_corrector> @linkml:Boolean ? ;
          <phase_plate> @linkml:Boolean ? ;
          <detector_technology> [ <https://w3id.org/aims-leaf/DetectorTechnologyEnum#direct_electron_detector>
             <https://w3id.org/aims-leaf/DetectorTechnologyEnum#ccd> <https://w3id.org/aims-leaf/DetectorTechnologyEnum#cmos>
             <https://w3id.org/aims-leaf/DetectorTechnologyEnum#hybrid_photon_counting>
             <https://w3id.org/aims-leaf/DetectorTechnologyEnum#scintillator_coupled>
             <https://w3id.org/aims-leaf/DetectorTechnologyEnum#imaging_plate>
             <https://w3id.org/aims-leaf/DetectorTechnologyEnum#film>
             <https://w3id.org/aims-leaf/DetectorTechnologyEnum#ion_chamber>
             <https://w3id.org/aims-leaf/DetectorTechnologyEnum#sdd> <https://w3id.org/aims-leaf/DetectorTechnologyEnum#sili>
             <https://w3id.org/aims-leaf/DetectorTechnologyEnum#hpge>
             <https://w3id.org/aims-leaf/DetectorTechnologyEnum#photodiode>
             <https://w3id.org/aims-leaf/DetectorTechnologyEnum#maia> ] ? ;
          <detector_manufacturer> @linkml:String ? ;
          <detector_model> @linkml:String ? ;
          <detector_mode> [ <https://w3id.org/aims-leaf/DetectorModeEnum#counting>
             <https://w3id.org/aims-leaf/DetectorModeEnum#integrating>
             <https://w3id.org/aims-leaf/DetectorModeEnum#super_resolution> <https://w3id.org/aims-leaf/DetectorModeEnum#linear>
             <https://w3id.org/aims-leaf/DetectorModeEnum#correlated_double_sampling> ] ? ;
          <detector_position> @linkml:String ? ;
          <detector_dimensions> @linkml:String ? ;
          <pixel_size_physical_um> @<QuantityValue> ? ;
          <autoloader_capacity> @<QuantityValue> ? ;
          <cs> @<QuantityValue> ? ;
          <c2_aperture> @<QuantityValue> ? ;
          <objective_aperture> @<QuantityValue> ? ;
          <phase_plate_type> @linkml:String ? ;
          <energy_filter_present> @linkml:Boolean ? ;
          <energy_filter_make> @linkml:String ? ;
          <energy_filter_model> @linkml:String ? ;
          <energy_filter_slit_width> @<QuantityValue> ? ;
          <pixel_size_physical> @<QuantityValue> ? ;
          <microscope_software> @linkml:String ? ;
          <microscope_software_version> @linkml:String ? ;
          <spotsize> @<QuantityValue> ? ;
          <gunlens> @<QuantityValue> ? ;
          <imaging_mode> [ <https://w3id.org/aims-leaf/ImagingModeEnum#EFTEM> <https://w3id.org/aims-leaf/ImagingModeEnum#TEM>
             <https://w3id.org/aims-leaf/ImagingModeEnum#STEM> ] ? ;
          <tem_beam_diameter> @<QuantityValue> ?
       ) ;
       rdf:type [ <CryoEMInstrument> ]
    )
}

<CryoEMPreparation> CLOSED {
    (  $<CryoEMPreparation_tes> (  &<TechniqueSpecificPreparation_tes> ;
          rdf:type [ <TechniqueSpecificPreparation> ] ? ;
          <grid_type> [ <https://w3id.org/aims-leaf/GridTypeEnum#c_flat> <https://w3id.org/aims-leaf/GridTypeEnum#quantifoil>
             <https://w3id.org/aims-leaf/GridTypeEnum#lacey_carbon> <https://w3id.org/aims-leaf/GridTypeEnum#ultrathin_carbon>
             <https://w3id.org/aims-leaf/GridTypeEnum#gold> ] ? ;
          <support_film> @linkml:String ? ;
          <hole_size> @<QuantityValue> ? ;
          <vitrification_method> [ <https://w3id.org/aims-leaf/VitrificationMethodEnum#plunge_freezing>
             <https://w3id.org/aims-leaf/VitrificationMethodEnum#high_pressure_freezing>
             <https://w3id.org/aims-leaf/VitrificationMethodEnum#slam_freezing> ] ? ;
          <blot_time> @<QuantityValue> ? ;
          <blot_force> @<QuantityValue> ? ;
          <humidity_percentage> @<QuantityValue> ? ;
          <chamber_temperature> @<QuantityValue> ? ;
          <grid_material> [ <https://w3id.org/aims-leaf/GridMaterialEnum#carbon> <https://w3id.org/aims-leaf/GridMaterialEnum#gold>
             <https://w3id.org/aims-leaf/GridMaterialEnum#graphene> <https://w3id.org/aims-leaf/GridMaterialEnum#silicon_nitride> ]
          ? ;
          <glow_discharge_applied> @linkml:Boolean ? ;
          <glow_discharge_time> @<QuantityValue> ? ;
          <glow_discharge_current> @<QuantityValue> ? ;
          <glow_discharge_atmosphere> @linkml:String ? ;
          <glow_discharge_pressure> @<QuantityValue> ? ;
          <vitrification_instrument> @linkml:String ? ;
          <blot_number> @<QuantityValue> ? ;
          <wait_time> @<QuantityValue> ? ;
          <blotter_height> @<QuantityValue> ? ;
          <blotter_setting> @<QuantityValue> ? ;
          <sample_applied_volume> @<QuantityValue> ? ;
          <ethane_temperature> @<QuantityValue> ? ;
          <plasma_treatment> @linkml:String ?
       ) ;
       rdf:type [ <CryoEMPreparation> ] ?
    )
}

<CTFEstimationParameters> CLOSED {
    (  $<CTFEstimationParameters_tes> (  &<AttributeGroup_tes> ;
          rdf:type [ <AttributeGroup> ] ? ;
          <defocus_search_min> @<QuantityValue> ? ;
          <defocus_search_max> @<QuantityValue> ? ;
          <defocus_step> @<QuantityValue> ? ;
          <amplitude_contrast> @<QuantityValue> ? ;
          <cs_used_in_estimation> @<QuantityValue> ? ;
          <voltage_used_in_estimation> @<QuantityValue> ?
       ) ;
       rdf:type [ <CTFEstimationParameters> ] ?
    )
}

<https://w3id.org/aims-leaf/functional_annotation/DatabaseCrossReference> CLOSED {
    (  $<https://w3id.org/aims-leaf/functional_annotation/DatabaseCrossReference_tes> (  &<AttributeGroup_tes> ;
          rdf:type [ <AttributeGroup> ] ? ;
          <https://w3id.org/aims-leaf/functional_annotation/database_name> [
             <https://w3id.org/aims-leaf/functional_annotation/DatabaseNameEnum#uniprot>
             <https://w3id.org/aims-leaf/functional_annotation/DatabaseNameEnum#pdb>
             <https://w3id.org/aims-leaf/functional_annotation/DatabaseNameEnum#pfam>
             <https://w3id.org/aims-leaf/functional_annotation/DatabaseNameEnum#cath>
             <https://w3id.org/aims-leaf/functional_annotation/DatabaseNameEnum#scop>
             <https://w3id.org/aims-leaf/functional_annotation/DatabaseNameEnum#interpro>
             <https://w3id.org/aims-leaf/functional_annotation/DatabaseNameEnum#chembl>
             <https://w3id.org/aims-leaf/functional_annotation/DatabaseNameEnum#chebi>
             <https://w3id.org/aims-leaf/functional_annotation/DatabaseNameEnum#pubchem>
             <https://w3id.org/aims-leaf/functional_annotation/DatabaseNameEnum#drugbank>
             <https://w3id.org/aims-leaf/functional_annotation/DatabaseNameEnum#omim>
             <https://w3id.org/aims-leaf/functional_annotation/DatabaseNameEnum#clinvar>
             <https://w3id.org/aims-leaf/functional_annotation/DatabaseNameEnum#cosmic>
             <https://w3id.org/aims-leaf/functional_annotation/DatabaseNameEnum#gnomad>
             <https://w3id.org/aims-leaf/functional_annotation/DatabaseNameEnum#intact>
             <https://w3id.org/aims-leaf/functional_annotation/DatabaseNameEnum#string>
             <https://w3id.org/aims-leaf/functional_annotation/DatabaseNameEnum#biogrid>
             <https://w3id.org/aims-leaf/functional_annotation/DatabaseNameEnum#reactome>
             <https://w3id.org/aims-leaf/functional_annotation/DatabaseNameEnum#kegg>
             <https://w3id.org/aims-leaf/functional_annotation/DatabaseNameEnum#go> ] ;
          <https://w3id.org/aims-leaf/functional_annotation/database_id> @linkml:String ;
          <https://w3id.org/aims-leaf/functional_annotation/database_url> @linkml:Uri ? ;
          <https://w3id.org/aims-leaf/functional_annotation/last_updated> @linkml:String ?
       ) ;
       rdf:type [ <https://w3id.org/aims-leaf/functional_annotation/DatabaseCrossReference> ] ?
    )
}

<DataCollectionStrategy> CLOSED {
    (  $<DataCollectionStrategy_tes> (  &<AttributeGroup_tes> ;
          rdf:type [ <AttributeGroup> ] ? ;
          <collection_mode> [ <https://w3id.org/aims-leaf/CollectionModeEnum#counting>
             <https://w3id.org/aims-leaf/CollectionModeEnum#super_resolution>
             <https://w3id.org/aims-leaf/CollectionModeEnum#continuous> <https://w3id.org/aims-leaf/CollectionModeEnum#oscillation>
             <https://w3id.org/aims-leaf/CollectionModeEnum#still> <https://w3id.org/aims-leaf/CollectionModeEnum#batch>
             <https://w3id.org/aims-leaf/CollectionModeEnum#sec_saxs>
             <https://w3id.org/aims-leaf/CollectionModeEnum#single_particle> ] ? ;
          <total_frames> @<QuantityValue> ? ;
          <frame_rate> @<QuantityValue> ? ;
          <total_dose> @<QuantityValue> ? ;
          <dose_per_frame> @<QuantityValue> ? ;
          <wavelength_a> @<QuantityValue> ? ;
          <detector_mode> [ <https://w3id.org/aims-leaf/DetectorModeEnum#counting>
             <https://w3id.org/aims-leaf/DetectorModeEnum#integrating>
             <https://w3id.org/aims-leaf/DetectorModeEnum#super_resolution> <https://w3id.org/aims-leaf/DetectorModeEnum#linear>
             <https://w3id.org/aims-leaf/DetectorModeEnum#correlated_double_sampling> ] ? ;
          <pixel_size_calibrated> @<QuantityValue> ? ;
          <detector_distance_mm> @<QuantityValue> ? ;
          <beam_center_x_px> @<QuantityValue> ? ;
          <beam_center_y_px> @<QuantityValue> ? ;
          <beam_size_um> @<QuantityValue> ? ;
          <flux_photons_per_s> @<QuantityValue> ? ;
          <transmission_percent> @<QuantityValue> ? ;
          <attenuator> @linkml:String ? ;
          <temperature_k> @<QuantityValue> ? ;
          <oscillation_per_image_deg> @<QuantityValue> ? ;
          <total_rotation_deg> @<QuantityValue> ? ;
          <strategy_notes> @linkml:String ?
       ) ;
       rdf:type [ <DataCollectionStrategy> ] ?
    )
}

<DataFile>  (
    CLOSED {
       (  $<DataFile_tes> (  &<NamedThing_tes> ;
             rdf:type [ <NamedThing> ] ? ;
             <file_name> @linkml:String ;
             <file_path> @linkml:String ? ;
             <file_format> [ <https://w3id.org/aims-leaf/FileFormatEnum#mrc> <https://w3id.org/aims-leaf/FileFormatEnum#tiff>
                <https://w3id.org/aims-leaf/FileFormatEnum#ometiff> <https://w3id.org/aims-leaf/FileFormatEnum#hdf5>
                <https://w3id.org/aims-leaf/FileFormatEnum#star> <https://w3id.org/aims-leaf/FileFormatEnum#pdb>
                <https://w3id.org/aims-leaf/FileFormatEnum#mmcif> <https://w3id.org/aims-leaf/FileFormatEnum#mtz>
                <https://w3id.org/aims-leaf/FileFormatEnum#cbf> <https://w3id.org/aims-leaf/FileFormatEnum#cbf_zst>
                <https://w3id.org/aims-leaf/FileFormatEnum#img> <https://w3id.org/aims-leaf/FileFormatEnum#h5>
                <https://w3id.org/aims-leaf/FileFormatEnum#ascii> <https://w3id.org/aims-leaf/FileFormatEnum#thermo_raw>
                <https://w3id.org/aims-leaf/FileFormatEnum#zip> <https://w3id.org/aims-leaf/FileFormatEnum#mrcs>
                <https://w3id.org/aims-leaf/FileFormatEnum#eer> <https://w3id.org/aims-leaf/FileFormatEnum#cs>
                <https://w3id.org/aims-leaf/FileFormatEnum#json> <https://w3id.org/aims-leaf/FileFormatEnum#csv>
                <https://w3id.org/aims-leaf/FileFormatEnum#ccp4> <https://w3id.org/aims-leaf/FileFormatEnum#gz> ] ;
             <file_size_bytes> @<QuantityValue> ? ;
             <checksum> @linkml:String ? ;
             <creation_date> @linkml:Date ? ;
             <data_type> [ <https://w3id.org/aims-leaf/DataTypeEnum#micrograph>
                <https://w3id.org/aims-leaf/DataTypeEnum#diffraction> <https://w3id.org/aims-leaf/DataTypeEnum#scattering>
