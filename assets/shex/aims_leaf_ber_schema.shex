             <https://w3id.org/aims-leaf/WorkflowTypeEnum#mass_spec_deconvolution>
             <https://w3id.org/aims-leaf/WorkflowTypeEnum#particle_extraction>
             <https://w3id.org/aims-leaf/WorkflowTypeEnum#ab_initio> <https://w3id.org/aims-leaf/WorkflowTypeEnum#postprocessing>
             <https://w3id.org/aims-leaf/WorkflowTypeEnum#map_validation>
             <https://w3id.org/aims-leaf/WorkflowTypeEnum#model_refinement>
             <https://w3id.org/aims-leaf/WorkflowTypeEnum#model_validation>
             <https://w3id.org/aims-leaf/WorkflowTypeEnum#xrf_analysis> <https://w3id.org/aims-leaf/WorkflowTypeEnum#ftir_analysis>
             <https://w3id.org/aims-leaf/WorkflowTypeEnum#image_processing> ] ;
          <processing_level> @<QuantityValue> ? ;
          <software_name> @linkml:String ;
          <software_version> @linkml:String ? ;
          <additional_software> @linkml:String ? ;
          <processing_parameters> @linkml:String ? ;
          <parameters_file_path> @linkml:String ?
       ) ;
       rdf:type [ <WorkflowRun> ]
    )
}

<XRayInstrument> CLOSED {
    (  $<XRayInstrument_tes> (  &<Instrument_tes> ;
          rdf:type [ <Instrument> ] ? ;
          <source_type> [ <https://w3id.org/aims-leaf/XRaySourceTypeEnum#synchrotron>
             <https://w3id.org/aims-leaf/XRaySourceTypeEnum#rotating_anode>
             <https://w3id.org/aims-leaf/XRaySourceTypeEnum#microfocus> <https://w3id.org/aims-leaf/XRaySourceTypeEnum#metal_jet> ]
          ? ;
          nsls2:Detector [ <https://w3id.org/aims-leaf/DetectorTechnologyEnum#direct_electron_detector>
             <https://w3id.org/aims-leaf/DetectorTechnologyEnum#ccd> <https://w3id.org/aims-leaf/DetectorTechnologyEnum#cmos>
             <https://w3id.org/aims-leaf/DetectorTechnologyEnum#hybrid_photon_counting>
             <https://w3id.org/aims-leaf/DetectorTechnologyEnum#scintillator_coupled>
             <https://w3id.org/aims-leaf/DetectorTechnologyEnum#imaging_plate>
             <https://w3id.org/aims-leaf/DetectorTechnologyEnum#film>
             <https://w3id.org/aims-leaf/DetectorTechnologyEnum#ion_chamber>
             <https://w3id.org/aims-leaf/DetectorTechnologyEnum#sdd> <https://w3id.org/aims-leaf/DetectorTechnologyEnum#sili>
             <https://w3id.org/aims-leaf/DetectorTechnologyEnum#hpge>
             <https://w3id.org/aims-leaf/DetectorTechnologyEnum#photodiode>
             <https://w3id.org/aims-leaf/DetectorTechnologyEnum#maia> ] ? ;
          <detector_manufacturer> @linkml:String ? ;
          <detector_model> @linkml:String ? ;
          <energy_min> @<QuantityValue> ? ;
          <energy_max> @<QuantityValue> ? ;
          <beam_size_min> @<QuantityValue> ? ;
          <beam_size_max> @<QuantityValue> ? ;
          <flux_density> @<QuantityValue> ? ;
          <monochromator_type> @linkml:String ? ;
          <goniometer_type> @linkml:String ? ;
          <crystal_cooling_capability> @linkml:Boolean ?
       ) ;
       rdf:type [ <XRayInstrument> ]
    )
}

<XRayPreparation> CLOSED {
    (  $<XRayPreparation_tes> (  &<TechniqueSpecificPreparation_tes> ;
          rdf:type [ <TechniqueSpecificPreparation> ] ? ;
          <protein_concentration_mg_per_ml> @<QuantityValue> ? ;
          <protein_buffer> @linkml:String ? ;
          <additives> @linkml:String ? ;
          <crystallization_method> [ <https://w3id.org/aims-leaf/CrystallizationMethodEnum#vapor_diffusion_hanging>
             <https://w3id.org/aims-leaf/CrystallizationMethodEnum#vapor_diffusion_sitting>
             <https://w3id.org/aims-leaf/CrystallizationMethodEnum#batch>
             <https://w3id.org/aims-leaf/CrystallizationMethodEnum#microbatch>
             <https://w3id.org/aims-leaf/CrystallizationMethodEnum#lcp>
             <https://w3id.org/aims-leaf/CrystallizationMethodEnum#dialysis>
             <https://w3id.org/aims-leaf/CrystallizationMethodEnum#free_interface_diffusion> ] ? ;
          <screen_name> @linkml:String ? ;
          <temperature_c> @<QuantityValue> ? ;
          <drop_ratio_protein_to_reservoir> @linkml:String ? ;
          <drop_volume_nl> @<QuantityValue> ? ;
          <reservoir_volume_ul> @<QuantityValue> ? ;
          <seeding_type> @linkml:String ? ;
          <seed_stock_dilution> @linkml:String ? ;
          <initial_hit_condition> @linkml:String ? ;
          <optimization_strategy> @linkml:String ? ;
          <optimized_condition> @linkml:String ? ;
          <crystal_size_um> @linkml:String ? ;
          <cryoprotectant> @linkml:String ? ;
          <cryoprotectant_concentration> @<QuantityValue> ? ;
          <soak_compound> @linkml:String ? ;
          <soak_conditions> @linkml:String ? ;
          nsls2:Mount_Type @linkml:String ? ;
          <flash_cooling_method> @linkml:String ? ;
          <crystal_notes> @linkml:String ? ;
          nsls2:Loop_Size @<QuantityValue> ? ;
          nsls2:Temperature @<QuantityValue> ?
       ) ;
       rdf:type [ <XRayPreparation> ] ?
    )
}

<XRFImage> CLOSED {
    (  $<XRFImage_tes> (  &<DataFile_tes> ;
          rdf:type [ <DataFile> ] ? ;
          <pixel_size> @<QuantityValue> ? ;
          <dimensions_x> @<QuantityValue> ? ;
          <dimensions_y> @<QuantityValue> ? ;
          <beam_energy> @<QuantityValue> ? ;
          <beam_size> @<QuantityValue> ? ;
          <dwell_time> @<QuantityValue> ? ;
          <elements_measured> @linkml:String * ;
          <source_type> [ <https://w3id.org/aims-leaf/XRaySourceTypeEnum#synchrotron>
             <https://w3id.org/aims-leaf/XRaySourceTypeEnum#rotating_anode>
             <https://w3id.org/aims-leaf/XRaySourceTypeEnum#microfocus> <https://w3id.org/aims-leaf/XRaySourceTypeEnum#metal_jet> ]
          ? ;
          <detector_technology> [ <https://w3id.org/aims-leaf/DetectorTechnologyEnum#direct_electron_detector>
             <https://w3id.org/aims-leaf/DetectorTechnologyEnum#ccd> <https://w3id.org/aims-leaf/DetectorTechnologyEnum#cmos>
             <https://w3id.org/aims-leaf/DetectorTechnologyEnum#hybrid_photon_counting>
             <https://w3id.org/aims-leaf/DetectorTechnologyEnum#scintillator_coupled>
             <https://w3id.org/aims-leaf/DetectorTechnologyEnum#imaging_plate>
             <https://w3id.org/aims-leaf/DetectorTechnologyEnum#film>
             <https://w3id.org/aims-leaf/DetectorTechnologyEnum#ion_chamber>
             <https://w3id.org/aims-leaf/DetectorTechnologyEnum#sdd> <https://w3id.org/aims-leaf/DetectorTechnologyEnum#sili>
             <https://w3id.org/aims-leaf/DetectorTechnologyEnum#hpge>
             <https://w3id.org/aims-leaf/DetectorTechnologyEnum#photodiode>
             <https://w3id.org/aims-leaf/DetectorTechnologyEnum#maia> ] ? ;
          <detector_model> @linkml:String ? ;
          <flux> @<QuantityValue> ? ;
          <calibration_standard> @linkml:String ?
       ) ;
       rdf:type [ <XRFImage> ]
    )
}
