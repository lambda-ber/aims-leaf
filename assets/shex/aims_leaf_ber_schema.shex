          <color_channels> @linkml:String * ;
          <white_balance> @linkml:String ? ;
          <contrast_method> @linkml:String ?
       ) ;
       rdf:type [ <OpticalImage> ]
    )
}

<ParticlePickingParameters> CLOSED {
